<!doctype html>
<html lang="{{ request.locale.iso_code }}">

<head>
  {% # Inlined CSS Variables %}
  {% render 'css-variables' %}
  {{ 'header.css' | asset_url | stylesheet_tag }}
  {{ 'mega-menu.css' | asset_url | stylesheet_tag }}
  {% comment %}
  Font preloading:
  1. Preconnect to font CDN for faster connection
  2. Preload the critical font variants for initial page render
  3. Additional variants load on-demand via @font-face
  {% endcomment %}
  {% unless settings.type_heading_font.system? or settings.type_body_font.system? %}
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  {% endunless %}

  {% unless settings.type_heading_font.system? %}
  {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
  {% endunless %}

  {% unless settings.type_body_font.system? %}
  {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
  {% endunless %}

  {% # Load and preload the critical CSS %}
  {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

  {% # Social, title, etc. %}
  {% render 'meta-tags' %}

  {{ content_for_header }}
</head>

<body>
  {% sections 'header-group' %}

  {{ content_for_layout }}

  {% sections 'footer-group' %}
  {{ 'megemenu-script.js' | asset_url | script_tag }}

  {{ 'header-script.js' | asset_url | script_tag }}
  <script src="{{ 'lenis.min.js' | asset_url }}" defer></script>
  <script src="{{ 'lenis.js' | asset_url }}" defer></script>
  {{ 'scroll-animate.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'scroll-animate.js' | asset_url }}" defer></script>
</body>

</html>