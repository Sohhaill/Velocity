<script>
  // Use a namespace to prevent re-declaration issues
  window.HeaderApp = window.HeaderApp || {
    init: function() {
      // 1. Accordion Toggle (Using Event Delegation)
      // This allows the click to work even after Shopify reloads the section
      if (!this.initialized) {
        document.addEventListener('click', (e) => {
          const toggle = e.target.closest('.header__drawer-submenu-toggle');
          if (toggle) {
            this.handleAccordion(toggle);
          }
        });
        
        // 2. Global Close Listeners (Only attach once)
        document.addEventListener('click', (event) => {
          var drawer = document.getElementById('header-drawer');
          if (!drawer || !drawer.classList.contains('header__drawer--open')) return;
          if (event.target.closest('.header__drawer-panel')) return;
          if (event.target.closest('.header__toggle')) return;
          this.closeHeaderDrawer();
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            this.closeHeaderDrawer();
            this.closeSearchPopup();
          }
        });

        document.addEventListener('click', (event) => {
          if (event.target.closest('[data-search-popup-close]')) {
            this.closeSearchPopup();
          }
        });
        
        this.initialized = true;
      }
    },

    openHeaderDrawer: function(event) {
      if (event && event.isTrusted === false) return;
      var drawer = document.getElementById('header-drawer');
      if (!drawer) return;
      drawer.classList.add('header__drawer--open');
      drawer.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('header-drawer-open');
      document.body.style.overflow = 'hidden';
      if (window.lenis) window.lenis.stop();
    },

    closeHeaderDrawer: function() {
      var drawer = document.getElementById('header-drawer');
      if (!drawer) return;
      drawer.classList.remove('header__drawer--open');
      drawer.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('header-drawer-open');
      document.body.style.overflow = '';
      if (window.lenis) window.lenis.start();
    },

    openSearchPopup: function() {
      var popup = document.getElementById('search-popup');
      var input = document.getElementById('search-popup-input');
      if (!popup) return;
      popup.classList.add('search-popup--open');
      popup.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('search-popup-open');
      if (input) {
        setTimeout(() => input.focus(), 100);
      }
      document.body.style.overflow = 'hidden';
      if (window.lenis) window.lenis.stop();
    },

    closeSearchPopup: function() {
      var popup = document.getElementById('search-popup');
      if (!popup) return;
      popup.classList.remove('search-popup--open');
      popup.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('search-popup-open');
      document.body.style.overflow = '';
      if (window.lenis) window.lenis.start();
    },

    handleAccordion: function(toggle) {
      var item = toggle.closest('.header__drawer-item');
      var submenu = item ? item.querySelector(':scope > .header__drawer-submenu') : null;
      if (!item || !submenu) return;

      var isOpen = item.classList.contains('header__drawer-item--open');
      if (isOpen) {
        item.classList.remove('header__drawer-item--open');
        toggle.setAttribute('aria-expanded', 'false');
        submenu.style.maxHeight = '0px';
      } else {
        item.classList.add('header__drawer-item--open');
        toggle.setAttribute('aria-expanded', 'true');
        submenu.style.maxHeight = submenu.scrollHeight + 'px';
      }
    }
  };

  // Map the global functions back to the ones used in your HTML onclicks
  window.openHeaderDrawer = window.HeaderApp.openHeaderDrawer;
  window.closeHeaderDrawer = window.HeaderApp.closeHeaderDrawer;
  window.openSearchPopup = window.HeaderApp.openSearchPopup;
  window.closeSearchPopup = window.HeaderApp.closeSearchPopup;

  // Initialize on load
  window.HeaderApp.init();

  // THE FIX FOR THE EDITOR:
  // This listener detects when you change a setting in the Shopify Editor
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      // Ensure all popups are closed when a setting changes to prevent "flashing"
      window.HeaderApp.closeHeaderDrawer();
      window.HeaderApp.closeSearchPopup();
    }
  });
</script>