{%- comment -%}
  Mega Menu Snippet
  ------------------------------------------------------------------
  Usage (render this from inside header-menu-item.liquid, once per
  top-level <li> that has a matching block):

    {% render 'mega-menu', block: mega_menu_block, link: link %}

  block : the schema block object (type "mega_menu_collection" or
          "mega_menu_banner") that was matched to this menu item
  link  : the menu link object for this top-level item — used to pull
          its sub-menu links into the left column
{%- endcomment -%}

{%- liquid
  assign mm_type = block.type
-%}

<div
  class="mega-menu mega-menu--{{ mm_type }}"
  id="MegaMenu-{{ block.id }}"
  data-mega-menu
  aria-hidden="true"
>
  <div class="mega-menu__inner {% if section.settings.header_width_type == 'full_width' %} header--full-width{% else %} container-width{% endif %}">

    {%- case mm_type -%}

      {%- when 'mega_menu_collection' -%}

        <div class="mega-menu__col mega-menu__col--links">
          {%- render 'mega-menu-submenu', link: link -%}
        </div>

        <div class="mega-menu__col mega-menu__col--collections">
          {%- for i in (1..3) -%}
            {%- assign coll_key = 'collection_' | append: i -%}
            {%- assign title_key = coll_key | append: '_title' -%}
            {%- assign mm_collection = block.settings[coll_key] -%}
            {%- if mm_collection != blank -%}
              <a href="{{ mm_collection.url }}" class="mega-menu__coll-card">
                <div class="mega-menu__coll-image-wrap">
                  {%- if mm_collection.featured_image -%}
                    {{ mm_collection.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mega-menu__coll-image', alt: mm_collection.title }}
                  {%- else -%}
                    <div class="mega-menu__coll-placeholder"></div>
                  {%- endif -%}
                  <span class="mega-menu__coll-overlay"></span>
                </div>
                <span class="mega-menu__coll-title">
                  {{ block.settings[title_key] | default: mm_collection.title }}
                </span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

      {%- when 'mega_menu_banner' -%}

        <div class="mega-menu__col mega-menu__col--text">
          {%- if block.settings.heading != blank -%}
            <p class="mega-menu__heading">{{ block.settings.heading }}</p>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <div class="mega-menu__subheading">{{ block.settings.subheading }}</div>
          {%- endif -%}
          {%- render 'mega-menu-submenu', link: link -%}
        </div>

        <div class="mega-menu__col mega-menu__col--banners">
          {%- for i in (1..3) -%}
            {%- assign img_key = 'banner_' | append: i | append: '_image' -%}
            {%- assign title_key = 'banner_' | append: i | append: '_title' -%}
            {%- assign sub_key = 'banner_' | append: i | append: '_subtitle' -%}
            {%- assign link_key = 'banner_' | append: i | append: '_link' -%}
            {%- assign btn_key = 'banner_' | append: i | append: '_button_label' -%}
            {%- assign mm_image = block.settings[img_key] -%}
            {%- if mm_image != blank -%}
              <a href="{{ block.settings[link_key] | default: '#' }}" class="mega-menu__banner-card">
                <div class="mega-menu__banner-image-wrap">
                  {{ mm_image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'mega-menu__banner-image', alt: block.settings[title_key] }}
                  <span class="mega-menu__banner-overlay"></span>
                </div>
                <div class="mega-menu__banner-content">
                  {%- if block.settings[title_key] != blank -%}
                    <span class="mega-menu__banner-title">{{ block.settings[title_key] }}</span>
                  {%- endif -%}
                  {%- if block.settings[sub_key] != blank -%}
                    <span class="mega-menu__banner-subtitle">{{ block.settings[sub_key] }}</span>
                  {%- endif -%}
                  {%- if block.settings[btn_key] != blank -%}
                    <span class="mega-menu__banner-btn">{{ block.settings[btn_key] }}</span>
                  {%- endif -%}
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>

    {%- endcase -%}

  </div>
</div>
