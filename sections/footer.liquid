{% assign footer_width_class = 'container-width' %}
{% if section.settings.footer_width_type == 'full_width' %}
  {% assign footer_width_class = 'full-width' %}
{% endif %}

<footer class="footer section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }} {{ footer_width_class }}">
  <div class="footer__top container-width">
    <div class="footer__brand-column">
      {% if section.settings.logo %}
        <a class="footer__logo-link" href="{{ routes.root_url }}">
          {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | image_tag: class: 'footer__logo footer__logo--desktop', alt: shop.name }}
          {% if section.settings.logo_mobile %}
            {{ section.settings.logo_mobile | image_url: width: section.settings.logo_width_mobile | image_tag: class: 'footer__logo footer__logo--mobile', alt: shop.name }}
          {% else %}
            <span class="footer__logo-spacer footer__logo--mobile"></span>
          {% endif %}
        </a>
      {% endif %}

      <div class="footer__socials">
        {% if settings.footer_facebook_url != blank %}
          <a class="footer__social-button" href="{{ settings.footer_facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M14 9h2V6h-2c-2.2 0-4 1.8-4 4v2H8v3h2v6h3v-6h2.4l.6-3H13v-2c0-.6.4-1 1-1Z"/></svg>
          </a>
        {% endif %}
        {% if settings.footer_instagram_url != blank %}
          <a class="footer__social-button" href="{{ settings.footer_instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="5" y="5" width="14" height="14" rx="4" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.8"/><circle cx="16.5" cy="7.5" r="1.1" fill="currentColor"/></svg>
          </a>
        {% endif %}
        {% if settings.footer_youtube_url != blank %}
          <a class="footer__social-button" href="{{ settings.footer_youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="6.5" width="18" height="11" rx="3" stroke="currentColor" stroke-width="1.8"/><path d="M10 10.5L15 12L10 13.5V10.5Z" fill="currentColor"/></svg>
          </a>
        {% endif %}
        {% if settings.footer_twitter_url != blank %}
          <a class="footer__social-button" href="{{ settings.footer_twitter_url }}" target="_blank" rel="noopener" aria-label="Twitter">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18.4 7.4c.01.16.01.32.01.49 0 4.98-3.79 10.72-10.72 10.72A10.66 10.66 0 0 1 2 16.9a7.59 7.59 0 0 0 5.59-1.56 3.77 3.77 0 0 1-3.52-2.62c.56.1 1.15.06 1.7-.06A3.76 3.76 0 0 1 2.76 8.96v-.05c.52.29 1.12.46 1.76.48A3.77 3.77 0 0 1 3.37 4.3a10.68 10.68 0 0 0 7.75 3.93 3.76 3.76 0 0 1 6.4-3.43 7.56 7.56 0 0 0 2.4-.92 3.8 3.8 0 0 1-1.65 2.08 7.5 7.5 0 0 0 2.17-.6 8.13 8.13 0 0 1-2.04 2.14Z" fill="currentColor"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="footer__blocks">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'menu' %}
            {% if block.settings.menu != blank %}
              <div class="footer__block footer__block--{{ block.settings.width }}" {{ block.shopify_attributes }}>
                {% if block.settings.heading != blank %}
                  <h3 class="footer__block-heading">{{ block.settings.heading }}</h3>
                {% endif %}
                <ul class="footer__menu-list">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          {% when 'subscribe' %}
            <div class="footer__block footer__block--{{ block.settings.width }}" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="footer__block-heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% form 'customer', class: 'footer__subscribe' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" required placeholder="{{ block.settings.placeholder | default: 'Enter your email' | escape }}">
                <button type="submit">{{ block.settings.button_label | default: 'Subscribe' }}</button>
              {% endform %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>

  <div class="footer__bottom container-width">
    <div class="footer__bottom-left">
      {% if settings.footer_payment_icon_1 != blank or settings.footer_payment_icon_2 != blank or settings.footer_payment_icon_3 != blank or settings.footer_payment_icon_4 != blank or settings.footer_payment_icon_5 != blank or settings.footer_payment_icon_6 != blank or settings.footer_payment_icon_7 != blank or settings.footer_payment_icon_8 != blank %}
        <div class="footer__payment">
          {% if settings.footer_payment_icon_1 != blank %}<img src="{{ settings.footer_payment_icon_1 | image_url }}" alt="Payment icon 1">{% endif %}
          {% if settings.footer_payment_icon_2 != blank %}<img src="{{ settings.footer_payment_icon_2 | image_url }}" alt="Payment icon 2">{% endif %}
          {% if settings.footer_payment_icon_3 != blank %}<img src="{{ settings.footer_payment_icon_3 | image_url }}" alt="Payment icon 3">{% endif %}
          {% if settings.footer_payment_icon_4 != blank %}<img src="{{ settings.footer_payment_icon_4 | image_url }}" alt="Payment icon 4">{% endif %}
          {% if settings.footer_payment_icon_5 != blank %}<img src="{{ settings.footer_payment_icon_5 | image_url }}" alt="Payment icon 5">{% endif %}
          {% if settings.footer_payment_icon_6 != blank %}<img src="{{ settings.footer_payment_icon_6 | image_url }}" alt="Payment icon 6">{% endif %}
          {% if settings.footer_payment_icon_7 != blank %}<img src="{{ settings.footer_payment_icon_7 | image_url }}" alt="Payment icon 7">{% endif %}
          {% if settings.footer_payment_icon_8 != blank %}<img src="{{ settings.footer_payment_icon_8 | image_url }}" alt="Payment icon 8">{% endif %}
        </div>
      {% endif %}
    </div>
    <div class="footer__bottom-right">
      {% if section.settings.bottom_menu != blank %}
        <ul class="footer__bottom-menu">
          {% for link in linklists[section.settings.bottom_menu].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    padding: 3rem 0 1.5rem;
    position: relative;
  }

  .footer__top,
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer__top {
    padding-bottom: 2.5rem;
  }

  .footer__brand-column {
    flex: 0 0 260px;
  }

  .footer__logo {
    display: block;
    height: auto;
    max-width: 100%;
  }

  .footer__logo--mobile {
    display: none;
  }

  .footer__logo-spacer {
    display: none;
  }

  .footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .footer__social-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: inherit;
    transition: background-color 0.25s ease, transform 0.25s ease;
  }

  .footer__social-button:hover,
  .footer__social-button:focus-visible {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-2px);
  }

  .footer__social-button svg {
    width: 2.1rem;
    height: 2.1rem;
    fill: currentColor;
    stroke: currentColor;
  }

  .footer__blocks {
    display: flex;
    flex-wrap: wrap;
    flex: 1;
    gap: 1.5rem 2rem;
  }

  .footer__block {
    box-sizing: border-box;
    max-width: 100%;
    min-width: 180px;
  }

  .footer__block--20 {
    flex: 1 1 calc(20% - 1.6rem);
  }

  .footer__block--25 {
    flex: 1 1 calc(25% - 1.5rem);
  }

  .footer__block--33 {
    flex: 1 1 calc(33.333% - 1.34rem);
  }

  .footer__block--50 {
    flex: 1 1 calc(50% - 1rem);
  }

  .footer__block--100 {
    flex: 1 1 100%;
  }

  .footer__block-heading {
    margin: 0 0 1.1rem;
    position: relative;
    padding-bottom: 0.6rem;
  }

  .footer__block-heading::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 2rem;
    height: 2px;
    background: currentColor;
    opacity: 0.35;
  }

  .footer__menu-list,
  .footer__bottom-menu {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__menu-list li + li,
  .footer__bottom-menu li + li {
    margin-top: 0.65rem;
  }

  .footer__menu-list a,
  .footer__bottom-menu a {
    color: inherit;
    text-decoration: none;
    display: inline-block;
    opacity: 0.8;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .footer__menu-list a:hover,
  .footer__menu-list a:focus-visible,
  .footer__bottom-menu a:hover,
  .footer__bottom-menu a:focus-visible {
    opacity: 1;
    transform: translateX(3px);
  }

  .footer__subscribe {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer__subscribe input {
    flex: 1 1 auto;
    min-width: 160px;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.04);
    color: inherit;
    box-sizing: border-box;
  }

  .footer__subscribe button {
    flex: 0 0 auto;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    color: inherit;
    cursor: pointer;
    transition: background-color 0.25s ease, transform 0.25s ease;
  }

  .footer__subscribe button:hover,
  .footer__subscribe button:focus-visible {
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-1px);
  }

  .footer__bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    align-items: center;
    flex-wrap: wrap;
  }

  .footer__payment {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .footer__payment img {
    height: 24px;
    width: auto;
    display: block;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .footer__payment img:hover {
    opacity: 1;
  }

  .footer__bottom-menu {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.25rem;
  }

  .footer__bottom-menu li + li {
    margin-top: 0;
  }

  @media (max-width: 860px) {
    .footer__top,
    .footer__bottom,
    .footer__blocks {
      flex-direction: column;
    }

    .footer__block--20,
    .footer__block--25,
    .footer__block--33,
    .footer__block--50,
    .footer__block--100,
    .footer__brand-column {
      flex: 1 1 auto;
    }

    .footer__logo--desktop {
      display: none;
    }

    .footer__logo--mobile,
    .footer__logo-spacer {
      display: block;
    }

    .footer__brand-column {
      text-align: center;
    }

    .footer__socials {
      justify-content: center;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
      gap: 1.25rem;
    }

    .footer__subscribe {
      flex-direction: column;
    }

    .footer__subscribe button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "select",
      "id": "section_color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme_1",
      "options": [
        { "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
        { "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" }
      ]
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "image_picker",
      "id": "logo_mobile",
      "label": "Logo mobile"
    },
    {
      "type": "select",
      "id": "footer_width_type",
      "label": "Footer width",
      "default": "container_width",
      "options": [
        { "value": "container_width", "label": "Container width" },
        { "value": "full_width", "label": "Full width" }
      ]
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "t:labels.logo_width_desktop",
      "min": 80,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "t:labels.logo_width_mobile",
      "min": 60,
      "max": 260,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom menu"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "33",
          "options": [
            { "value": "20", "label": "20%" },
            { "value": "25", "label": "25%" },
            { "value": "33", "label": "33%" },
            { "value": "50", "label": "50%" },
            { "value": "100", "label": "100%" }
          ]
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "subscribe",
      "name": "Subscribe block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Subscribe"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "default": "33",
          "options": [
            { "value": "20", "label": "20%" },
            { "value": "25", "label": "25%" },
            { "value": "33", "label": "33%" },
            { "value": "50", "label": "50%" },
            { "value": "100", "label": "100%" }
          ]
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Email placeholder",
          "default": "Enter your email"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
