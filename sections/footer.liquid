{{ 'footer.css' | asset_url | stylesheet_tag }}

{% assign footer_width_class = 'container-width' %}
{% if section.settings.footer_width_type == 'full_width' %}
{% assign footer_width_class = 'full-width' %}
{% endif %}
{% assign footer_logo_styles = '--footer-logo-width-desktop: ' | append: section.settings.logo_width_desktop | append:
'px; --footer-logo-width-mobile: ' | append: section.settings.logo_width_mobile | append: 'px;' %}

<footer class="footer section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }} ">
  <div class="footer__top {{ footer_width_class }}">
    <div class="footer__brand-column">
      {% if section.settings.logo %}
      <a class="footer__logo-link" href="{{ routes.root_url }}">
        {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | image_tag: class:
        'footer__logo', alt: shop.name, loading: 'lazy', style: footer_logo_styles }}
      </a>
      {% endif %}

      {% if section.settings.footer_text != blank %}
      <p class="footer__text">{{ section.settings.footer_text }}</p>
      {% endif %}

      <div class="footer__socials">

        {% if settings.footer_facebook_url != blank %}

        <a class="footer__social-button" href="{{ settings.footer_facebook_url }}" target="_blank" rel="noopener"
          aria-label="Facebook">
          {{ 'icon-fb.svg' | inline_asset_content }}
        </a>
        {% endif %}
        {% if settings.footer_instagram_url != blank %}
        <a class="footer__social-button" href="{{ settings.footer_instagram_url }}" target="_blank" rel="noopener"
          aria-label="Instagram">
          {{ 'icon-insta.svg' | inline_asset_content }}
        </a>
        {% endif %}
        {% if settings.footer_youtube_url != blank %}
        <a class="footer__social-button" href="{{ settings.footer_youtube_url }}" target="_blank" rel="noopener"
          aria-label="YouTube">
          {{ 'icon-youtube.svg' | inline_asset_content }}
        </a>
        {% endif %}
        {% if settings.footer_twitter_url != blank %}
        <a class="footer__social-button" href="{{ settings.footer_twitter_url }}" target="_blank" rel="noopener"
          aria-label="Twitter">
          {{ 'icon-twitter.svg' | inline_asset_content }}
        </a>
        {% endif %}
      </div>
    </div>

    <div class="footer__blocks">
      {% for block in section.blocks %}
      {% case block.type %}
      {% when 'menu' %}
      {% if block.settings.menu != blank %}
      <div
        class="footer__block footer__block--{{ block.settings.width }}{% if block.settings.open_by_default %} footer__block--open{% endif %}"
        {{ block.shopify_attributes }}>
        {% if block.settings.heading != blank %}
        <button class="footer__block-heading" type="button" data-footer-menu-toggle
          aria-expanded="{% if block.settings.open_by_default %}true{% else %}false{% endif %}">
          <span>{{ block.settings.heading }}</span>
          <span class="footer__block-icon" aria-hidden="true"></span>
        </button>
        {% endif %}
        <ul class="footer__menu-list">
          {% for link in block.settings.menu.links %}
          <li>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% when 'subscribe' %}
      <div class="footer__block footer__block--{{ block.settings.width }}" {{ block.shopify_attributes }}>
        {% if block.settings.heading != blank %}
        <h4 class="footer__block-heading">{{ block.settings.heading }}</h4>
        {% endif %}
        {% form 'customer', class: 'footer__subscribe' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" required
          placeholder="{{ block.settings.placeholder | default: 'Enter your email' | escape }}">
        <button type="submit">{{ block.settings.button_label | default: 'Subscribe' }}</button>
        {% endform %}
      </div>
      {% endcase %}
      {% endfor %}
    </div>
  </div>

  {%- if section.settings.show_footer_bottom -%}
  <div class="footer__bottom">

    <div class="container-width bottom-inner">
      {%- if section.settings.show_currency_selector -%}
      {%- if localization.available_countries.size > 1 -%}
      <div class="footer__currency-row">
        {% form 'localization', id: 'FooterLocalizationForm', class: 'footer__localization-form' %}

        {%- if localization.available_countries.size > 1 -%}
        <div class="footer__currency-item">
          <select id="FooterCountrySelector" name="country_code" aria-label="Country / Currency"
            onchange="this.form.submit()">
            {%- for country in localization.available_countries -%}
            <option value="{{ country.iso_code }}" {% if country.iso_code==localization.country.iso_code %}selected{%
              endif %}>
              {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
            </option>
            {%- endfor -%}
          </select>

          <svg class="footer__currency-caret" width="10" height="6" viewBox="0 0 10 6" fill="none"
            xmlns="http://www.w3.org/2000/svg">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </div>
        {%- endif -%}

        {%- if localization.available_languages.size > 1 -%}
        <div class="footer__language-item">
          <select id="FooterLanguageSelector" name="locale_code" aria-label="Language" onchange="this.form.submit()">
            {%- for language in localization.available_languages -%}
            <option value="{{ language.iso_code }}" {% if language.iso_code==localization.language.iso_code %}selected{%
              endif %}>
              {{ language.endonym_name }}
            </option>
            {%- endfor -%}
          </select>

          
        </div>
        {%- endif -%}

        {% endform %}
      </div>
      {%- endif -%}
      {%- endif -%}
      <div class="footer__bottom-left">
        {% if section.settings.show_bottom_menu and section.settings.bottom_menu != blank %}
        <ul class="footer__bottom-menu">
          {% for link in linklists[section.settings.bottom_menu].links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
        {% endif %}

      </div>
      {% if section.settings.show_payment_icons %}
      <div class="footer__bottom-right">

        {% if settings.footer_payment_icon_1 != blank or settings.footer_payment_icon_2 != blank or
        settings.footer_payment_icon_3 != blank or settings.footer_payment_icon_4 != blank or
        settings.footer_payment_icon_5 != blank or settings.footer_payment_icon_6 != blank or
        settings.footer_payment_icon_7 != blank or settings.footer_payment_icon_8 != blank %}
        <div class="footer__payment">
          {% if settings.footer_payment_icon_1 != blank %}<img src="{{ settings.footer_payment_icon_1 | image_url }}"
            alt="Payment icon 1">{% endif %}
          {% if settings.footer_payment_icon_2 != blank %}<img src="{{ settings.footer_payment_icon_2 | image_url }}"
            alt="Payment icon 2">{% endif %}
          {% if settings.footer_payment_icon_3 != blank %}<img src="{{ settings.footer_payment_icon_3 | image_url }}"
            alt="Payment icon 3">{% endif %}
          {% if settings.footer_payment_icon_4 != blank %}<img src="{{ settings.footer_payment_icon_4 | image_url }}"
            alt="Payment icon 4">{% endif %}
          {% if settings.footer_payment_icon_5 != blank %}<img src="{{ settings.footer_payment_icon_5 | image_url }}"
            alt="Payment icon 5">{% endif %}
          {% if settings.footer_payment_icon_6 != blank %}<img src="{{ settings.footer_payment_icon_6 | image_url }}"
            alt="Payment icon 6">{% endif %}
          {% if settings.footer_payment_icon_7 != blank %}<img src="{{ settings.footer_payment_icon_7 | image_url }}"
            alt="Payment icon 7">{% endif %}
          {% if settings.footer_payment_icon_8 != blank %}<img src="{{ settings.footer_payment_icon_8 | image_url }}"
            alt="Payment icon 8">{% endif %}
        </div>
        {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
  {%- endif -%}

</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const desktopQuery = window.matchMedia('(min-width: 861px)');

    document.querySelectorAll('.footer__block').forEach((block) => {
      const toggle = block.querySelector('[data-footer-menu-toggle]');
      if (!toggle) return;

      toggle.addEventListener('click', () => {
        if (desktopQuery.matches) return;

        const isOpen = block.classList.toggle('footer__block--open');
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    });
  });
</script>



{% schema %}
{
"name": "t:general.footer",
"settings": [
{
"type": "select",
"id": "section_color_scheme",
"label": "t:labels.color_scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
{ "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
{ "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
]
},
{
"type": "image_picker",
"id": "logo",
"label": "t:labels.logo"
},
{
"type": "select",
"id": "footer_width_type",
"label": "Footer width",
"default": "container_width",
"options": [
{ "value": "container_width", "label": "Container width" },
{ "value": "full_width", "label": "Full width" }
]
},
{
"type": "range",
"id": "logo_width_desktop",
"label": "t:labels.logo_width_desktop",
"min": 80,
"max": 400,
"step": 10,
"unit": "px",
"default": 220
},
{
"type": "range",
"id": "logo_width_mobile",
"label": "t:labels.logo_width_mobile",
"min": 60,
"max": 260,
"step": 10,
"unit": "px",
"default": 160
},
{
"type": "link_list",
"id": "bottom_menu",
"label": "Bottom menu"
},
{
"type": "checkbox",
"id": "show_currency_selector",
"label": "Show currency/country selector",
"default": true
},
{
"type": "textarea",
"id": "footer_text",
"label": "t:labels.footer_text",
"default": "We're here to help you find exactly what you're looking for, with quality you can trust and support"
},
{
"type": "header",
"content": "t:headers.footer_bottom"
},
{
"type": "checkbox",
"id": "show_footer_bottom",
"label": "t:labels.show_footer_bottom",
"default": true
},
{
"type": "checkbox",
"id": "show_bottom_menu",
"label": "t:labels.show_bottom_menu",
"default": true
},
{
"type": "checkbox",
"id": "show_payment_icons",
"label": "t:labels.show_payment_icons",
"default": true
}
],
"blocks": [
{
"type": "menu",
"name": "Menu column",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading"
},
{
"type": "checkbox",
"id": "open_by_default",
"label": "Open by default",
"default": false
},
{
"type": "select",
"id": "width",
"label": "Width",
"default": "33",
"options": [
{ "value": "20", "label": "20%" },
{ "value": "25", "label": "25%" },
{ "value": "33", "label": "33%" },
{ "value": "50", "label": "50%" },
{ "value": "100", "label": "100%" }
]
},
{
"type": "link_list",
"id": "menu",
"label": "Menu"
}
]
},
{
"type": "subscribe",
"name": "Subscribe block",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Subscribe"
},
{
"type": "select",
"id": "width",
"label": "Width",
"default": "33",
"options": [
{ "value": "20", "label": "20%" },
{ "value": "25", "label": "25%" },
{ "value": "33", "label": "33%" },
{ "value": "50", "label": "50%" },
{ "value": "100", "label": "100%" }
]
},
{
"type": "text",
"id": "placeholder",
"label": "Email placeholder",
"default": "Enter your email"
},
{
"type": "text",
"id": "button_label",
"label": "Button label",
"default": "Subscribe"
}
]
}
],
"max_blocks": 4
}
{% endschema %}