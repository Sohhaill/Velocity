{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

<div class="v-annoucment" data-v-annoucment data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
  <div class="v-annoucment__inner page-width">

    {%- comment -%} LEFT: SOCIAL ICONS (reference: footer settings) {%- endcomment -%}
    <div class="v-annoucment__col v-annoucment__col--left">
      {%- if section.settings.show_social_icons -%}
        <div class="v-annoucment__socials">
          {% if settings.footer_facebook_url != blank %}
          <a class="v-annoucment__social-button" href="{{ settings.footer_facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
