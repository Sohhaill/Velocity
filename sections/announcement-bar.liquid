            </svg>
          </a>
          {% endif %}
          {% if settings.footer_instagram_url != blank %}
          <a class="v-annoucment__social-button" href="{{ settings.footer_instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="800px" height="800px" viewBox="0 0 24 24" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M12 18C15.3137 18 18 15.3137 18 12C18 8.68629 15.3137 6 12 6C8.68629 6 6 8.68629 6 12C6 15.3137 8.68629 18 12 18ZM12 16C14.2091 16 16 14.2091 16 12C16 9.79086 14.2091 8 12 8C9.79086 8 8 9.79086 8 12C8 14.2091 9.79086 16 12 16Z" fill="currentColor" />
              <path d="M18 5C17.4477 5 17 5.44772 17 6C17 6.55228 17.4477 7 18 7C18.5523 7 19 6.55228 19 6C19 5.44772 18.5523 5 18 5Z" fill="currentColor" />
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1.65396 4.27606C1 5.55953 1 7.23969 1 10.6V13.4C1 16.7603 1 18.4405 1.65396 19.7239C2.2292 20.8529 3.14708 21.7708 4.27606 22.346C5.55953 23 7.23969 23 10.6 23H13.4C16.7603 23 18.4405 23 19.7239 22.346C20.8529 21.7708 21.7708 20.8529 22.346 19.7239C23 18.4405 23 16.7603 23 13.4V10.6C23 7.23969 23 5.55953 22.346 4.27606C21.7708 3.14708 20.8529 2.2292 19.7239 1.65396C18.4405 1 16.7603 1 13.4 1H10.6C7.23969 1 5.55953 1 4.27606 1.65396C3.14708 2.2292 2.2292 3.14708 1.65396 4.27606ZM13.4 3H10.6C8.88684 3 7.72225 3.00156 6.82208 3.0751C5.94524 3.14674 5.49684 3.27659 5.18404 3.43597C4.43139 3.81947 3.81947 4.43139 3.43597 5.18404C3.27659 5.49684 3.14674 5.94524 3.0751 6.82208C3.00156 7.72225 3 8.88684 3 10.6V13.4C3 15.1132 3.00156 16.2777 3.0751 17.1779C3.14674 18.0548 3.27659 18.5032 3.43597 18.816C3.81947 19.5686 4.43139 20.1805 5.18404 20.564C5.49684 20.7234 5.94524 20.8533 6.82208 20.9249C7.72225 20.9984 8.88684 21 10.6 21H13.4C15.1132 21 16.2777 20.9984 17.1779 20.9249C18.0548 20.8533 18.5032 20.7234 18.816 20.564C19.5686 20.1805 20.1805 19.5686 20.564 18.816C20.7234 18.5032 20.8533 18.0548 20.9249 17.1779C20.9984 16.2777 21 15.1132 21 13.4V10.6C21 8.88684 20.9984 7.72225 20.9249 6.82208C20.8533 5.94524 20.7234 5.49684 20.564 5.18404C20.1805 4.43139 19.5686 3.81947 18.816 3.43597C18.5032 3.27659 18.0548 3.14674 17.1779 3.0751C16.2777 3.00156 15.1132 3 13.4 3Z" fill="currentColor" />
            </svg>
          </a>
          {% endif %}
          {% if settings.footer_youtube_url != blank %}
          <a class="v-annoucment__social-button" href="{{ settings.footer_youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="800px" height="800px" viewBox="0 0 192 192" preserveAspectRatio="xMidYMid" style="display:block">
              <defs>
                <linearGradient id="v-annoucment-yt-a">
                  <stop offset="0" style="stop-color:#000000;stop-opacity:1" />
                  <stop offset="1" style="stop-color:#000000;stop-opacity:0" />
                </linearGradient>
                <linearGradient xlink:href="#v-annoucment-yt-a" id="v-annoucment-yt-b" x1="2.004" x2="21.998" y1="12" y2="12" gradientTransform="matrix(1.02105 0 0 1.00561 -.247 -.067)" gradientUnits="userSpaceOnUse" />
              </defs>
              <g style="fill:url(#v-annoucment-yt-b);fill-opacity:1;stroke-width:1.01331" transform="matrix(7.83738 0 0 6.96095 1.899 12.469)">
                <path fill="red" d="M21.39 13.19v-.22c-.01-.86-.5-5-.78-5.74-.32-.85-.76-1.5-1.31-1.91-.9-.67-1.66-.82-2.6-.84h-.02c-.4 0-3.01.32-5.2.62-2.2.3-4.95.7-5.6.94-.9.33-1.62.77-2.19 1.33-1.05 1.04-1.18 2.11-1.04 3.51.1 1.09.69 5.37 1.02 6.35.45 1.32 1.33 2.12 2.47 2.24.28.03.55.05.82.05 1 0 1.8-.21 2.72-.46 1.45-.39 3.25-.87 6.97-.87h.11c.91 0 3.14-.2 4.16-2.07.52-1 .49-2.21.47-2.93z" style="fill:none;fill-opacity:1;stroke:currentColor ;stroke-width:1.62466;stroke-dasharray:none;stroke-opacity:1" />
                <path fill="currentColor" d="M11.59 14.76c-.48.36-.8.45-1.01.45a.54.54 0 0 1-.3-.08c-.34-.18-.42-.61-.5-1.2l-.01-.1c-.04-.31-.26-2.1-.38-3.16l-.09-.73c-.04-.28-.1-.75.24-1 .32-.23.75-.09.96-.03.53.17 3.6 1.23 4.59 1.73.21.09.67.28.68.83.01.5-.38.74-.53.82z" style="fill:none;fill-opacity:1;stroke:currentColor ;stroke-width:1.62466;stroke-dasharray:none;stroke-opacity:1" />
              </g>
            </svg>
          </a>
          {% endif %}
          {% if settings.footer_twitter_url != blank %}
          <a class="v-annoucment__social-button" href="{{ settings.footer_twitter_url }}" target="_blank" rel="noopener" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865z" />
            </svg>
          </a>
          {% endif %}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} CENTER: ROTATING TEXT {%- endcomment -%}
    <div class="v-annoucment__col v-annoucment__col--center">
      {%- if section.blocks.size > 0 -%}
        <div class="v-annoucment__ticker">
          {%- for block in section.blocks -%}
            {%- if block.type == 'text' -%}
              <p class="v-annoucment__ticker-item{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
                {{- block.settings.text -}}
              </p>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: LOCALIZATION {%- endcomment -%}
    <div class="v-annoucment__col v-annoucment__col--right">
      {%- if section.settings.enable_localization -%}
        {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          {% form 'localization', id: 'VAnnoucmentLocalizationForm', class: 'v-annoucment__localization' %}
            {%- if localization.available_countries.size > 1 -%}
              <div class="v-annoucment__loc-item">
                <select id="VAnnoucmentCountrySelector" name="country_code" aria-label="Country / Currency" onchange="this.form.submit()">
                  {%- for country in localization.available_countries -%}
                    <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
                      {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="v-annoucment__loc-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {%- endif -%}
            {%- if localization.available_languages.size > 1 -%}
              <div class="v-annoucment__loc-item">
                <select id="VAnnoucmentLanguageSelector" name="locale_code" aria-label="Language" onchange="this.form.submit()">
                  {%- for language in localization.available_languages -%}
                    <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                      {{ language.endonym_name }}
                    </option>
                  {%- endfor -%}
                </select>
                <svg class="v-annoucment__loc-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {%- endif -%}
          {% endform %}
        {%- endif -%}
      {%- endif -%}
    </div>

  </div>
</div>

<style>
  .v-annoucment {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
  }
</style>


<script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>
{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "t:sections.announcement-bar.settings.show_social_icons.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_localization",
      "label": "t:sections.announcement-bar.settings.enable_localization.label",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "t:sections.announcement-bar.settings.autoplay_speed.label",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.announcement-bar.settings.header_colors.content"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.announcement-bar.settings.bg_color.label",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.announcement-bar.settings.text_color.label",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.announcement-bar.blocks.text.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.announcement-bar.blocks.text.settings.text.label",
          "default": "Free shipping on all orders over $50"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        { "type": "text" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}