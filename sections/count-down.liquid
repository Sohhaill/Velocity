{{ 'count-down.css' | asset_url | stylesheet_tag }}

{% assign v_cntdwn_styles = '--v-cntdwn-padding-top-desktop: ' | append: section.settings.padding_top_desktop | append: 'px; --v-cntdwn-padding-bottom-desktop: ' | append: section.settings.padding_bottom_desktop | append: 'px; --v-cntdwn-padding-top-mobile: ' | append: section.settings.padding_top_mobile | append: 'px; --v-cntdwn-padding-bottom-mobile: ' | append: section.settings.padding_bottom_mobile | append: 'px;' %}

{%- comment -%}
  Combine date + time text settings into a single ISO-ish string.
  JS will parse this with `new Date(...)`. Browser local timezone applies.
{%- endcomment -%}
{% assign v_cntdwn_time = section.settings.end_time | default: '00:00' %}
{% assign v_cntdwn_target = section.settings.end_date | append: 'T' | append: v_cntdwn_time | append: ':00' %}

<div
  class="v-cntdwn section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }}"
  id="v-cntdwn-{{ section.id }}"
  data-v-cntdwn
  data-end-date="{% if section.settings.end_date != blank %}{{ v_cntdwn_target }}{% endif %}"
  data-expire-action="{{ section.settings.on_expire }}"
  style="{{ v_cntdwn_styles }}"
>
  <div class="v-cntdwn__inner{% if section.settings.container_width_type == 'full_width' %} full-width{% else %} container-width{% endif %}">

    <div class="v-cntdwn__content" data-v-cntdwn-hide-on-expire>
      {%- if section.settings.heading != blank -%}
      <h2 class="v-cntdwn__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
      <div class="v-cntdwn__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.end_date != blank -%}
      <div class="v-cntdwn__timer" data-v-cntdwn-timer aria-live="polite">
        <div class="v-cntdwn__unit">
          <span class="v-cntdwn__number" data-days>00</span>
          <span class="v-cntdwn__label">{{ 'sections.count_down.days' | t }}</span>
        </div>
        <span class="v-cntdwn__separator">:</span>
        <div class="v-cntdwn__unit">
          <span class="v-cntdwn__number" data-hours>00</span>
          <span class="v-cntdwn__label">{{ 'sections.count_down.hours' | t }}</span>
        </div>
        <span class="v-cntdwn__separator">:</span>
        <div class="v-cntdwn__unit">
          <span class="v-cntdwn__number" data-minutes>00</span>
          <span class="v-cntdwn__label">{{ 'sections.count_down.minutes' | t }}</span>
        </div>
        <span class="v-cntdwn__separator">:</span>
        <div class="v-cntdwn__unit">
          <span class="v-cntdwn__number" data-seconds>00</span>
          <span class="v-cntdwn__label">{{ 'sections.count_down.seconds' | t }}</span>
        </div>
      </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      
        href="{{ section.settings.button_link }}"
        class="v-cntdwn__button button {% if section.settings.button_style == 'outline' %}button--outline{% else %}button--filled{% endif %}"
      >
        {{ section.settings.button_label }}
      </a>
      {%- endif -%}
    </div>

    {%- comment -%} Shown after timer hits zero, only when on_expire = hide_timer {%- endcomment -%}
    <div class="v-cntdwn__expired" data-v-cntdwn-expired hidden>
      {%- if section.settings.expired_text != blank -%}
        <p>{{ section.settings.expired_text }}</p>
      {%- endif -%}
    </div>

  </div>
</div>


{% schema %}
{
  "name": "t:sections.count_down.name",
  "class": "section-count-down",
  "settings": [
    {
      "type": "select",
      "id": "section_color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme_1",
      "options": [
        { "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
        { "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
        { "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
        { "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
      ]
    },
    {
      "type": "select",
      "id": "container_width_type",
      "label": "t:labels.Container_width_type",
      "default": "container_width",
      "options": [
        { "value": "container_width", "label": "t:options.Container_width_type.container_width" },
        { "value": "full_width", "label": "t:options.Container_width_type.full_width" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.count_down.headers.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.count_down.settings.heading.label",
      "default": "Sale ends in"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.count_down.settings.text.label",
      "default": "<p>Don't miss out on our limited time offer.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.count_down.headers.timer"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "t:sections.count_down.settings.end_date.label",
      "info": "t:sections.count_down.settings.end_date.info",
      "placeholder": "2026-12-31"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "t:sections.count_down.settings.end_time.label",
      "info": "t:sections.count_down.settings.end_time.info",
      "placeholder": "23:59",
      "default": "00:00"
    },
    {
      "type": "select",
      "id": "on_expire",
      "label": "t:sections.count_down.settings.on_expire.label",
      "default": "hide_timer",
      "options": [
        { "value": "hide_timer", "label": "t:options.on_expire.hide_timer" },
        { "value": "hide_section", "label": "t:options.on_expire.hide_section" },
        { "value": "show_zeros", "label": "t:options.on_expire.show_zeros" }
      ]
    },
    {
      "type": "text",
      "id": "expired_text",
      "label": "t:sections.count_down.settings.expired_text.label",
      "default": "This offer has ended",
      "info": "t:sections.count_down.settings.expired_text.info"
    },
    {
      "type": "header",
      "content": "t:sections.count_down.headers.button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.count_down.settings.button_label.label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.count_down.settings.button_link.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:labels.button_style",
      "default": "filled",
      "options": [
        { "value": "filled", "label": "t:options.button_style.filled" },
        { "value": "outline", "label": "t:options.button_style.outline" }
      ]
    },
    {
      "type": "header",
      "content": "t:labels.padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "t:labels.padding_top_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "t:labels.padding_bottom_desktop",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "t:labels.padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "t:labels.padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "t:sections.count_down.presets.name"
    }
  ]
}
{% endschema %}