{{ 'header.css' | asset_url | stylesheet_tag }}

<div class="section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }} v-header{% if section.settings.enable_drawer_desktop %} header--drawer-desktop{% endif %}"
  id="header-wrapper-{{ section.id }}" {% if section.settings.header_sticky %}data-header-sticky="true" {% endif %}>
  <header
    class="header{% if section.settings.header_width_type == 'full_width' %} header--full-width{% else %} container-width{% endif %}">
    {% assign header_logo_styles = '--header-logo-width-desktop: ' | append: section.settings.logo_width_desktop |
    append: 'px; --header-logo-width-mobile: ' | append: section.settings.logo_width_mobile | append: 'px;' %}
    <div class="header__inner">
      <button class="header__toggle" type="button" aria-expanded="false" aria-controls="header-drawer"
        onclick="openHeaderDrawer(event)">
        {{ 'icon-hamburger-simple.svg' | inline_asset_content }}
        <span class="visually-hidden">{{ 'header.open_menu' | t }}</span>
      </button>
      <div class="header__brand">
        <a class="header__brand-link" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
          {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | default: 280 | image_tag:
          class: 'header__logo', alt: shop.name }}
          {% else %}
          <span class="header__brand-text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>



      <nav class="header__nav" aria-label="{{ 'header.menu' | t }}">
        {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
        <ul class="header__menu-list">
          {% for link in section.settings.menu.links %}

            {%- assign mega_block = nil -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'mega_menu_editorial' or block.type == 'mega_menu_grid' -%}
                {%- if block.settings.menu_item_name != blank and block.settings.menu_item_name == link.title -%}
                  {%- assign mega_block = block -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if mega_block and mega_block.type == 'mega_menu_editorial' -%}
            <li class="header__menu-item header__mega-item" {{ mega_block.shopify_attributes }}>
              <div class="header__menu-link-wrap">
                <a class="header__menu-link" href="{{ link.url }}">{{ link.title }}</a>
              </div>
              <div class="header__mega-panel header__mega-panel--editorial">
                <div class="header__mega-inner container-width">
                  <div class="header__mega-feature">
                    {%- if mega_block.settings.feature_image != blank -%}
                    <div class="header__mega-feature-media">
                      {{ mega_block.settings.feature_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: mega_block.settings.feature_heading | escape }}
                    </div>
                    {%- endif -%}
                    {%- if mega_block.settings.feature_heading != blank -%}
                    <h3 class="header__mega-feature-heading">{{ mega_block.settings.feature_heading }}</h3>
                    {%- endif -%}
                    {%- if mega_block.settings.feature_subheading != blank -%}
                    <p class="header__mega-feature-subheading">{{ mega_block.settings.feature_subheading }}</p>
                    {%- endif -%}
                    {%- if mega_block.settings.feature_button_label != blank -%}
                    <a class="header__mega-feature-cta button--filled" href="{{ mega_block.settings.feature_button_url }}">
                      {{ mega_block.settings.feature_button_label }}
                    </a>
                    {%- endif -%}
                  </div>
                  <div class="header__mega-columns">
                    {%- if link.links and link.links.size > 0 -%}
                    <div class="header__mega-column">
                      <p class="header__mega-column-heading">{{ link.title }}</p>
                      <ul class="header__mega-column-list">
                        {%- for sub_link in link.links -%}
                        <li><a href="{{ sub_link.url }}">{{ sub_link.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    </div>
                    {%- endif -%}
                    {%- for i in (1..3) -%}
                      {%- assign col_menu_key = 'column_' | append: i | append: '_menu' -%}
                      {%- assign col_heading_key = 'column_' | append: i | append: '_heading' -%}
                      {%- assign col_menu = mega_block.settings[col_menu_key] -%}
                      {%- if col_menu != blank and col_menu.links.size > 0 -%}
                      <div class="header__mega-column">
                        {%- if mega_block.settings[col_heading_key] != blank -%}
                        <p class="header__mega-column-heading">{{ mega_block.settings[col_heading_key] }}</p>
                        {%- endif -%}
                        <ul class="header__mega-column-list">
                          {%- for col_link in col_menu.links -%}
                          <li><a href="{{ col_link.url }}">{{ col_link.title }}</a></li>
                          {%- endfor -%}
                        </ul>
                      </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </div>
            </li>

            {%- elsif mega_block and mega_block.type == 'mega_menu_grid' -%}
            <li class="header__menu-item header__mega-item" {{ mega_block.shopify_attributes }}>
              <div class="header__menu-link-wrap">
                <a class="header__menu-link" href="{{ link.url }}">{{ link.title }}</a>
              </div>
              <div class="header__mega-panel header__mega-panel--grid">
                <div class="header__mega-inner container-width">
                  <div class="header__mega-grid-layout">
                    {%- if link.links and link.links.size > 0 -%}
                    <div class="header__mega-grid-sublist">
                      <p class="header__mega-column-heading">{{ link.title }}</p>
                      <ul class="header__mega-column-list">
                        {%- for sub_link in link.links -%}
                        <li><a href="{{ sub_link.url }}">{{ sub_link.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    </div>
                    {%- endif -%}
                    <div class="header__mega-grid-main">
                  {%- if mega_block.settings.grid_heading != blank -%}
                  <p class="header__mega-grid-heading">{{ mega_block.settings.grid_heading }}</p>
                  {%- endif -%}
                  <div class="header__mega-grid">
                    {%- for i in (1..4) -%}
                      {%- assign card_img_key = 'card_' | append: i | append: '_image' -%}
                      {%- assign card_title_key = 'card_' | append: i | append: '_title' -%}
                      {%- assign card_url_key = 'card_' | append: i | append: '_url' -%}
                      {%- assign card_img = mega_block.settings[card_img_key] -%}
                      {%- assign card_title = mega_block.settings[card_title_key] -%}
                      {%- if card_img != blank or card_title != blank -%}
                      <a class="header__mega-card" href="{{ mega_block.settings[card_url_key] }}">
                        <div class="header__mega-card-media">
                          {%- if card_img != blank -%}
                          {{ card_img | image_url: width: 500 | image_tag: loading: 'lazy', alt: card_title | escape }}
                          {%- else -%}
                          {{ 'product-1' | placeholder_svg_tag: 'header__mega-placeholder-svg' }}
                          {%- endif -%}
                        </div>
                        {%- if card_title != blank -%}
                        <span class="header__mega-card-title">{{ card_title }}</span>
                        {%- endif -%}
                      </a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                    </div>
                  </div>
                  {%- if mega_block.settings.bottom_menu != blank and mega_block.settings.bottom_menu.links.size > 0 -%}
                  <ul class="header__mega-bottom-links">
                    {%- for blink in mega_block.settings.bottom_menu.links -%}
                    <li><a href="{{ blink.url }}">{{ blink.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                  {%- endif -%}
                </div>
              </div>
            </li>

            {%- else -%}
            {% render 'header-menu-item', link: link, mode: 'desktop', parent_id: 'desktop-', depth: 0, index:
            forloop.index0 %}
            {%- endif -%}

          {% endfor %}
        </ul>
        {% endif %}
      </nav>

      <div class="header__icons">
        {% if section.settings.show_wishlist_icon %}
        <a class="header__icon" href="/pages/wishlist" aria-label="{{ 'header.wishlist_icon' | t }}">
          {{ 'icon-wishlist.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
        <a class="header__icon hide-mobile" href="{{ routes.account_login_url }}"
          aria-label="{{ 'header.account_icon' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_search_icon %}
        <button class="header__icon" type="button" aria-label="{{ 'header.search_icon' | t }}"
          onclick="openSearchPopup()">
          {{ 'icon-search.svg' | inline_asset_content }}
        </button>
        {% endif %}

        {% if section.settings.show_cart_icon %}
        <a class="header__icon" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart_icon' | t }}">
          {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
          {% endif %}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
        {% endif %}
      </div>
    </div>

    <div id="header-drawer" class="header__drawer" aria-hidden="true">
      <div class="header__drawer-panel">
        <div class="header__drawer-top">
          <a class="header__drawer-brand" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
            {% if section.settings.logo %}
            {{ section.settings.logo | image_url: width: section.settings.logo_width_mobile | default: 180 | image_tag:
            class: 'header__logo', alt: shop.name }}
            {% else %}
            <span class="header__brand-text">{{ shop.name }}</span>
            {% endif %}
          </a>
          <button class="header__drawer-close" type="button" aria-label="{{ 'header.close_menu' | t }}"
            onclick="closeHeaderDrawer()">
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </div>

        <nav class="header__drawer-nav" aria-label="{{ 't:labels.menu' | t }}">
          {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
          <ul class="header__drawer-menu">
            {% for link in section.settings.menu.links %}
            {% render 'header-menu-item', link: link, mode: 'drawer', parent_id: 'drawer-', depth: 0, index:
            forloop.index0 %}
            {% endfor %}
          </ul>
          {% endif %}
        </nav>

        <div class="header__drawer-icons">
          <div class="drawer-socials">
            {% if settings.footer_facebook_url != blank %}
            {{ 'icon-fb.svg' | inline_asset_content }}
            {% endif %}
            {% if settings.footer_instagram_url != blank %}
            {{ 'icon-insta.svg' | inline_asset_content }}
            {% endif %}
            {% if settings.footer_youtube_url != blank %}
            {{ 'icon-youtube.svg' | inline_asset_content }}
            {% endif %}
            {% if settings.footer_twitter_url != blank %}
            {{ 'icon-twitter.svg' | inline_asset_content }}
            {% endif %}
          </div>
          {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
          <a class="header__drawer-icon" href="{{ routes.account_login_url }}">
            {{ 'icon-account.svg' | inline_asset_content }}
            <span>{{ 'header.account_icon' | t }}</span>
          </a>
          {% endif %}
          {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          {% form 'localization', id: 'DrawerLocalizationForm', class: 'drawer__localization' %}

          {%- if localization.available_countries.size > 1 -%}
          <div class="drawer__loc-item">
            <select id="DrawerCountrySelector" name="country_code" aria-label="Country / Currency"
              onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}" {% if country.iso_code==localization.country.iso_code %}selected{%
                endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
              {%- endfor -%}
            </select>


          </div>
          {%- endif -%}

          {%- if localization.available_languages.size > 1 -%}
          <div class="drawer__loc-item">
            <select id="DrawerLanguageSelector" name="locale_code" aria-label="Language" onchange="this.form.submit()">
              {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}" {% if language.iso_code==localization.language.iso_code
                %}selected{% endif %}>
                {{ language.endonym_name }}
              </option>
              {%- endfor -%}
            </select>


          </div>
          {%- endif -%}

          {% endform %}
          {%- endif -%}

        </div>
      </div>
    </div>

    {% render 'header-scripts' %}
    {% render 'search-popup', color_scheme: section.settings.search_popup_color_scheme %}
    {% if section.settings.header_sticky %}
    <script>
      (function () {
        var headerWrapper = document.getElementById('header-wrapper-{{ section.id }}');
        if (!headerWrapper) return;

        var scrollThreshold = 50; // px — scroll start ke baad sticky trigger hoga
        var isSticky = false;
        var ticking = false;

        function updateStickyState() {
          var scrolled = window.scrollY || window.pageYOffset;

          if (scrolled > scrollThreshold && !isSticky) {
            headerWrapper.classList.add('header--sticky');
            isSticky = true;
          } else if (scrolled <= scrollThreshold && isSticky) {
            headerWrapper.classList.remove('header--sticky');
            isSticky = false;
          }
        }

        window.addEventListener('scroll', function () {
          if (!ticking) {
            window.requestAnimationFrame(function () {
              updateStickyState();
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });

        // Page already scrolled hone par (anchor link se aane par) sahi state set karein
        updateStickyState();
      })();
    </script>
    {% endif %}
  </header>
</div>

<style>
  #shopify-section- {
      {
      section.id
    }
  }

    {

    --transition-default: 0.45s cubic-bezier(0.65, 0, 0.35, 1);
  }
</style>

{% schema %}
{
"name": "t:general.header",
"settings": [
{
"type": "select",
"id": "section_color_scheme",
"label": "t:labels.color_scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
{ "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
{ "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
]
},
{
"type": "image_picker",
"id": "logo",
"label": "t:labels.logo"
},
{
"type": "select",
"id": "header_width_type",
"label": "t:labels.header_width_type",
"default": "container_width",
"options": [
{ "value": "container_width", "label": "t:options.header_width_type.container_width" },
{ "value": "full_width", "label": "t:options.header_width_type.full_width" }
]
},
{
"type": "range",
"id": "logo_width_desktop",
"label": "t:labels.logo_width_desktop",
"min": 80,
"max": 400,
"step": 10,
"unit": "px",
"default": 280
},
{
"type": "range",
"id": "logo_width_mobile",
"label": "t:labels.logo_width_mobile",
"min": 60,
"max": 300,
"step": 10,
"unit": "px",
"default": 180
},
{
"type": "checkbox",
"id": "header_sticky",
"label": "t:labels.header_sticky",
"default": true
},
{
"type": "checkbox",
"id": "enable_drawer_desktop",
"label": "t:labels.enable_drawer_desktop",
"info": "t:labels.enable_drawer_desktop_info",
"default": false
},
{
"type": "link_list",
"id": "menu",
"label": "t:labels.menu"
},
{
"type": "checkbox",
"id": "show_wishlist_icon",
"label": "t:labels.wishlist_icon",
"default": true
},
{
"type": "checkbox",
"id": "show_account_icon",
"label": "t:labels.account_icon",
"default": true
},
{
"type": "checkbox",
"id": "show_search_icon",
"label": "t:labels.search_icon",
"default": false
},
{
"type": "select",
"id": "search_popup_color_scheme",
"label": "Search popup color scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
{ "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
{ "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
]
},
{
"type": "checkbox",
"id": "show_cart_icon",
"label": "t:labels.cart_icon",
"default": false
}
],
"blocks": [
{
"type": "mega_menu_editorial",
"name": "Mega Menu — Editorial",
"settings": [
{
"type": "text",
"id": "menu_item_name",
"label": "For item",
"info": "Type the exact menu item name (from the menu above) this mega menu should attach to."
},
{ "type": "header", "content": "Feature" },
{ "type": "image_picker", "id": "feature_image", "label": "Feature image" },
{ "type": "text", "id": "feature_heading", "label": "Feature heading", "default": "New Arrivals" },
{ "type": "text", "id": "feature_subheading", "label": "Feature subheading", "default": "Discover the latest drop" },
{ "type": "text", "id": "feature_button_label", "label": "Feature button label", "default": "Shop Now" },
{ "type": "url", "id": "feature_button_url", "label": "Feature button link" },
{ "type": "header", "content": "Column 1" },
{ "type": "text", "id": "column_1_heading", "label": "Column 1 heading" },
{ "type": "link_list", "id": "column_1_menu", "label": "Column 1 menu" },
{ "type": "header", "content": "Column 2" },
{ "type": "text", "id": "column_2_heading", "label": "Column 2 heading" },
{ "type": "link_list", "id": "column_2_menu", "label": "Column 2 menu" },
{ "type": "header", "content": "Column 3" },
{ "type": "text", "id": "column_3_heading", "label": "Column 3 heading" },
{ "type": "link_list", "id": "column_3_menu", "label": "Column 3 menu" }
]
},
{
"type": "mega_menu_grid",
"name": "Mega Menu — Grid",
"settings": [
{
"type": "text",
"id": "menu_item_name",
"label": "For item",
"info": "Type the exact menu item name (from the menu above) this mega menu should attach to."
},
{ "type": "text", "id": "grid_heading", "label": "Heading above grid" },
{ "type": "header", "content": "Card 1" },
{ "type": "image_picker", "id": "card_1_image", "label": "Image" },
{ "type": "text", "id": "card_1_title", "label": "Title" },
{ "type": "url", "id": "card_1_url", "label": "Link" },
{ "type": "header", "content": "Card 2" },
{ "type": "image_picker", "id": "card_2_image", "label": "Image" },
{ "type": "text", "id": "card_2_title", "label": "Title" },
{ "type": "url", "id": "card_2_url", "label": "Link" },
{ "type": "header", "content": "Card 3" },
{ "type": "image_picker", "id": "card_3_image", "label": "Image" },
{ "type": "text", "id": "card_3_title", "label": "Title" },
{ "type": "url", "id": "card_3_url", "label": "Link" },
{ "type": "header", "content": "Card 4" },
{ "type": "image_picker", "id": "card_4_image", "label": "Image" },
{ "type": "text", "id": "card_4_title", "label": "Title" },
{ "type": "url", "id": "card_4_url", "label": "Link" },
{ "type": "header", "content": "Bottom links (optional)" },
{ "type": "link_list", "id": "bottom_menu", "label": "Bottom menu" }
]
}
]
}
{% endschema %}