<div class="section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }}"
  id="header-wrapper-{{ section.id }}" {% if section.settings.header_sticky %}data-header-sticky="true" {% endif %}>
  <header
    class="header{% if section.settings.header_width_type == 'full_width' %} header--full-width{% else %} container-width{% endif %}">
    {% assign header_logo_styles = '--header-logo-width-desktop: ' | append: section.settings.logo_width_desktop |
    append: 'px; --header-logo-width-mobile: ' | append: section.settings.logo_width_mobile | append: 'px;' %}
    <div class="header__inner">
      <button class="header__toggle" type="button" aria-expanded="false" aria-controls="header-drawer"
        onclick="openHeaderDrawer()">
        {{ 'icon-hamburger-simple.svg' | inline_asset_content }}
        <span class="visually-hidden">{{ 'header.open_menu' | t }}</span>
      </button>
      <div class="header__brand">
        <a class="header__brand-link" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
          {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | default: 280 | image_tag:
          class: 'header__logo', alt: shop.name }}
          {% else %}
          <span class="header__brand-text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>



      <nav class="header__nav" aria-label="{{ 'header.menu' | t }}">
        {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
        <ul class="header__menu-list">
          {% for link in section.settings.menu.links %}
          {% render 'header-menu-item', link: link, mode: 'desktop', parent_id: 'desktop-', depth: 0, index:
          forloop.index0 %}
          {% endfor %}
        </ul>
        {% endif %}
      </nav>

      <div class="header__icons">
        {% if section.settings.show_wishlist_icon %}
        <a class="header__icon" href="/pages/wishlist" aria-label="{{ 'header.wishlist_icon' | t }}">
          {{ 'icon-wishlist.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
        <a class="header__icon hide-mobile" href="{{ routes.account_login_url }}"
          aria-label="{{ 'header.account_icon' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_search_icon %}
        <button class="header__icon" type="button" aria-label="{{ 'header.search_icon' | t }}"
          onclick="openSearchPopup()">
          {{ 'icon-search.svg' | inline_asset_content }}
        </button>
        {% endif %}

        {% if section.settings.show_cart_icon %}
        <a class="header__icon" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart_icon' | t }}">
          {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
          {% endif %}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
        {% endif %}
      </div>
    </div>

    <div id="header-drawer" class="header__drawer" aria-hidden="true">
      <div class="header__drawer-panel">
        <div class="header__drawer-top">
          <a class="header__drawer-brand" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
            {% if section.settings.logo %}
            {{ section.settings.logo | image_url: width: section.settings.logo_width_mobile | default: 180 | image_tag:
            class: 'header__logo', alt: shop.name }}
            {% else %}
            <span class="header__brand-text">{{ shop.name }}</span>
            {% endif %}
          </a>
          <button class="header__drawer-close" type="button" aria-label="{{ 'header.close_menu' | t }}"
            onclick="closeHeaderDrawer()">
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </div>

        <nav class="header__drawer-nav" aria-label="{{ 't:labels.menu' | t }}">
          {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
          <ul class="header__drawer-menu">
            {% for link in section.settings.menu.links %}
            {% render 'header-menu-item', link: link, mode: 'drawer', parent_id: 'drawer-', depth: 0, index:
            forloop.index0 %}
            {% endfor %}
          </ul>
          {% endif %}
        </nav>

        <div class="header__drawer-icons">

          {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
          <a class="header__drawer-icon" href="{{ routes.account_login_url }}">
            {{ 'icon-account.svg' | inline_asset_content }}
            <span>{{ 'header.account_icon' | t }}</span>
          </a>
          {% endif %}


        </div>
      </div>
    </div>

    {% render 'header-scripts' %}
    {% render 'search-popup', color_scheme: section.settings.search_popup_color_scheme %}
    {% if section.settings.header_sticky %}
    <script>
      (function () {
        var headerWrapper = document.getElementById('header-wrapper-{{ section.id }}');
        if (!headerWrapper) return;

        var scrollThreshold = 10; // px — scroll start ke baad sticky trigger hoga
        var isSticky = false;
        var ticking = false;

        function updateStickyState() {
          var scrolled = window.scrollY || window.pageYOffset;

          if (scrolled > scrollThreshold && !isSticky) {
            headerWrapper.classList.add('header--sticky');
            isSticky = true;
          } else if (scrolled <= scrollThreshold && isSticky) {
            headerWrapper.classList.remove('header--sticky');
            isSticky = false;
          }
        }

        window.addEventListener('scroll', function () {
          if (!ticking) {
            window.requestAnimationFrame(function () {
              updateStickyState();
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });

        // Page already scrolled hone par (anchor link se aane par) sahi state set karein
        updateStickyState();
      })();
    </script>
    {% endif %}
  </header>
</div>

{% stylesheet %}
#shopify-section-{{ section.id }} {
/* Single global transition variable for this section.
Change ONLY this line to update every animated transition
in the header, drawer, and submenus at once. */
--transition-default: 0.45s cubic-bezier(0.65, 0, 0.35, 1);
}

.header {
width: 100%;
background: var(--color-background);
color: var(--color-foreground);
padding-top: 20px;
padding-bottom: 20px;
}

.header--sticky {
position: -webkit-sticky;
position: sticky;
top: 0;
left: 0;
right: 0;
z-index: 1000;
width: 100%;
align-self: stretch;
}

.header__inner {
display: flex;
align-items: center;
justify-content: space-between;
gap: 1rem;
width: 100%;
margin: 0 auto;
}

.header--container-width .header__inner {
max-width: var(--header-max-width);
}

.header--full-width .header__inner {
max-width: 100%;
}

.header__brand-link {
display: inline-flex;
align-items: center;
width: var(--header-logo-width-desktop);
height: auto;
}

.header__drawer-brand {
display: inline-flex;
align-items: center;
width: var(--header-logo-width-mobile);
height: auto;
}

.header__logo {
display: block;
width: 100%;
height: 100%;
object-fit: cover;
}

.header__brand-text {
font-weight: 700;
font-size: 1.2rem;
}

.header__toggle {
display: none;
border: none;
background: transparent;
color: inherit;
cursor: pointer;
padding: unset;

}

.header__nav {
flex: 1;
}

.header__menu-list {
display: flex;
align-items: center;
gap: 1.5rem;
list-style: none;
justify-content: center;
margin: 0;
padding: 0;
}
.header button:hover{
background: unset;
color: unset;
}
.header__menu-item {
position: relative;
}

.header__menu-link {
color: inherit;
text-decoration: none;
opacity: 0.8;
font-weight: 500;
transition: all 0.25s ease;
}
.header__menu-item, .header__icon{
transition: all 0.25s ease;
}
.header__menu-item:hover{

transform: translateY(-5px);
}
.header__menu-item:hover a.header__menu-link{
opacity: 1;
}
.header__icon:hover{
transform: translateY(-5px);
}
.header__toggle svg,
.header__icon svg,
.header__submenu-toggle svg,
.header__drawer-submenu-toggle svg {

stroke: currentColor;
}

.header__menu-link-wrap {
display: inline-flex;
align-items: center;
gap: 0.25rem;
}

.header__submenu-toggle {
display: inline-flex;
align-items: center;
justify-content: center;
width: 11px;
height: 11px;

border: none;
background: transparent;
color: inherit;
cursor: pointer;
padding: 0;
}
.header__submenu-toggle svg{
width: 11px;
height: 11px;
}
.header__menu-item {
position: relative;
}

.header__menu-link {
color: inherit;
text-decoration: none;
}

.header__menu-link-wrap {
display: inline-flex;
align-items: center;
gap: 0.25rem;
}



.header__submenu {
position: absolute;
top: 100%;
left: 0;
background: var(--color-background);
border: 1px solid rgba(0, 0, 0, 0.08);
box-shadow: 0 10px 18px rgba(0, 0, 0, 0.08);
list-style: none;
margin: 0.15rem 0 0;
padding: 0.5rem 0;
min-width: 220px;
display: block;
opacity: 0;
visibility: hidden;
pointer-events: none;
transform: translateY(10px);
transition: opacity var(--transition-default), transform var(--transition-default), visibility 0s linear 0.35s;
z-index: 20;
}

.header__menu-item:hover > .header__submenu,
.header__menu-item:focus-within > .header__submenu {
opacity: 1;
visibility: visible;
pointer-events: auto;
transform: translateY(0);
transition-delay: 0s;
}

.header__submenu--depth-0 {
left: 0;
top: 100%;
}

.header__submenu--depth-1,
.header__submenu--depth-2,
.header__submenu--depth-3,
.header__submenu--depth-4 {
top: 0;
left: calc(100% + 0.5rem);
margin-top: 0;
}

.header__submenu .header__menu-item {
position: relative;
}

.header__submenu .header__menu-link-wrap {
width: 100%;
justify-content: space-between;
padding: 0.5rem 1rem;
}

.header__submenu .header__menu-link {
display: block;
flex: 1;
}

.header__icons {
display: flex;
align-items: center;
gap: 0.55rem;
}

.header__icon {
display: inline-flex;
align-items: center;
justify-content: center;
border: none;
background: transparent;
padding: 0;
cursor: pointer;
color: inherit;
text-decoration: none;
position: relative;
}

.header__icon sup {
position: absolute;
top: -0.35rem;
right: -0.35rem;
background: var(--color-foreground);
color: var(--color-background);
border-radius: 999px;
padding: 0 0.35rem;
font-size: 0.65rem;
line-height: 1;
}

.search-popup {
position: fixed;
inset: 0;
display: flex;
justify-content: center;
align-items: flex-start;
padding: 4rem 1rem 1rem;
background: transparent !important;
opacity: 0;
pointer-events: none;
transition: opacity var(--transition-default);
z-index: 200;
align-items: center;
}

.search-popup--open {
opacity: 1;
pointer-events: auto;
}

.search-popup__overlay {
position: absolute;
inset: 0;
background: rgba(0, 0, 0, 0.72);
z-index: 0;
backdrop-filter: blur(4px);
}

.search-popup__panel {
position: relative;
z-index: 1;
width: min(100%, 561px);
max-height: calc(100vh - 5rem);
overflow: auto;
padding: 1rem;
box-shadow: 0 24px 60px rgba(0, 0, 0, 0.32);
transform: translateY(16px);
transition: transform var(--transition-default);
}

.search-popup--open .search-popup__panel {
transform: translateY(0);
}

.search-popup__close {
display: inline-flex;
margin-left: auto;
border: none;
background: transparent;
color: inherit;
padding: 0;
}

.search-popup__form {
display: flex;
align-items: center;
gap: 0.75rem;
border: 1px solid rgba(255, 255, 255, 0.15);
padding: 1rem;
margin-top: 0.75rem;
}

.search-popup__submit {
border: none;
background: transparent;
color: inherit;
padding: 0;
display: inline-flex;
}

.search-popup__input {
flex: 1;
border: none;
background: transparent;
color: inherit;
outline: none;
font: inherit;
}

.search-popup__group {
margin-top: 1.25rem;
}

.search-popup__heading {
margin: 0 0 0.75rem;
font-size: 1rem;
}

.search-popup__chips {
display: flex;
flex-wrap: wrap;
gap: 0.75rem;
}

.search-popup__chip {
display: inline-flex;
align-items: center;
gap: 0.5rem;
padding: 0.65rem 0.9rem;
background: rgba(255, 255, 255, 0.08);
color: inherit;
text-decoration: none;
}

.search-popup__products {
display: grid;
grid-template-columns: repeat(2, minmax(0, 1fr));
gap: 1rem;
}

.search-popup__product {
color: inherit;
text-decoration: none;
}

.search-popup__product-media {
position: relative;
display: block;
aspect-ratio: 1 / 1;
overflow: hidden;
margin-bottom: 0.2rem;
background: rgba(255, 255, 255, 0.05);
}

.search-popup__product-image {
position: absolute;
inset: 0;
width: 100%;
height: 100%;
object-fit: cover;
transition: opacity var(--transition-default);
}

.search-popup__product-image--secondary {
opacity: 0;
}

.search-popup__product-media--has-hover:hover .search-popup__product-image--secondary {
opacity: 1;
}

.search-popup__product-media--has-hover:hover .search-popup__product-image--primary {
opacity: 0;
}

/* Drawer overlay */
.header__drawer {
position: fixed;
inset: 0;
background: rgba(0, 0, 0, 0.45);
display: flex;
align-items: flex-start;
justify-content: flex-start;
opacity: 0;
pointer-events: none;
transition: opacity var(--transition-default);
z-index: 100;
}

.header__drawer--open {
opacity: 1;
pointer-events: auto;
}

/* Drawer panel: full height, slides in from the left */
.header__drawer-panel {
width: 100%;
max-width: 467px;
height: 100%;
background: var(--color-background);
color: var(--color-foreground);
box-shadow: 2px 0 24px rgba(0, 0, 0, 0.16);
overflow-y: auto;
display: flex;
flex-direction: column;
transform: translateX(-100%);
transition: transform var(--transition-default);
}

.header__drawer--open .header__drawer-panel {
transform: translateX(0);
}

.header__drawer-top {
display: flex;
align-items: center;
justify-content: space-between;
padding: 1rem;
border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.header__drawer-close {
border: none;
background: transparent;
color: inherit;
cursor: pointer;
padding: 0.5rem;
}

.header__drawer-menu {
list-style: none;
margin: 0;
padding: 0;
}

.header__drawer-item {
border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}

.header__drawer-item-top {
display: flex;
align-items: center;
justify-content: space-between;
position: relative;
}

.header__drawer-item-top > a {
flex: 1;
display: block;
padding: 0.9rem 1rem;
color: inherit;
text-decoration: none;
}

.header__drawer-submenu-toggle {
border: none;
background: transparent;
color: inherit;
cursor: pointer;
padding: 0.9rem 1rem;
display: flex;
align-items: center;
justify-content: flex-end;
flex: 0 0 auto;
position: absolute;
width: 100%;
}

.header__drawer-submenu-toggle:hover {
background: unset;
color: unset;
}

.header__drawer-submenu-toggle svg {
transition: transform var(--transition-default);
}

.header__drawer-submenu-toggle[aria-expanded="true"] svg {
transform: rotate(180deg);
}

/* Accordion submenu: animated with JS-measured max-height, using the same transition variable */
.header__drawer-submenu {
list-style: none;
margin: 0;
padding: 0;
max-height: 0;
overflow: hidden;
transition: max-height var(--transition-default);
}

.header__drawer-submenu li .header__drawer-item-top > a {
display: block;
padding: 0.75rem 1rem 0.75rem calc(2rem + (var(--drawer-depth, 0) * 1rem));
}

.header__drawer-submenu li .header__drawer-submenu-toggle {
padding-right: 1rem;
}

.header__drawer-icons {
display: flex;
flex-direction: column;
gap: 0.5rem;
padding: 1rem;
margin-top: auto;
}

.header__drawer-icon {
display: inline-flex;
align-items: center;
gap: 0.75rem;
color: inherit;
text-decoration: none;
padding: 0.75rem 1rem;
border-radius: 0.75rem;
background: rgba(0, 0, 0, 0.03);
}

.header__drawer-icon span {
font-size: 0.95rem;
}

.visually-hidden {
position: absolute !important;
width: 1px;
height: 1px;
padding: 0;
margin: -1px;
overflow: hidden;
clip: rect(0, 0, 0, 0);
white-space: nowrap;
border: 0;
}

@media (max-width: 860px) {
.header__inner {
max-width: var(--header-max-width-mobile);
}

.header__nav
{
display: none;
}

.header__toggle {
display: inline-flex;
}

.header__submenu {
display: none;
}

.header__brand-link {
width: var(--header-logo-width-mobile);
}
}
{% endstylesheet %}

{% schema %}
{
"name": "t:general.header",
"settings": [
{
"type": "select",
"id": "section_color_scheme",
"label": "t:labels.color_scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" }
]
},
{
"type": "image_picker",
"id": "logo",
"label": "t:labels.logo"
},
{
"type": "select",
"id": "header_width_type",
"label": "t:labels.header_width_type",
"default": "container_width",
"options": [
{ "value": "container_width", "label": "t:options.header_width_type.container_width" },
{ "value": "full_width", "label": "t:options.header_width_type.full_width" }
]
},
{
"type": "range",
"id": "logo_width_desktop",
"label": "t:labels.logo_width_desktop",
"min": 80,
"max": 400,
"step": 10,
"unit": "px",
"default": 280
},
{
"type": "range",
"id": "logo_width_mobile",
"label": "t:labels.logo_width_mobile",
"min": 60,
"max": 300,
"step": 10,
"unit": "px",
"default": 180
},
{
"type": "checkbox",
"id": "header_sticky",
"label": "t:labels.header_sticky",
"default": true
},
{
"type": "link_list",
"id": "menu",
"label": "t:labels.menu"
},
{
"type": "checkbox",
"id": "show_wishlist_icon",
"label": "t:labels.wishlist_icon",
"default": true
},
{
"type": "checkbox",
"id": "show_account_icon",
"label": "t:labels.account_icon",
"default": true
},
{
"type": "checkbox",
"id": "show_search_icon",
"label": "t:labels.search_icon",
"default": false
},
{
"type": "select",
"id": "search_popup_color_scheme",
"label": "Search popup color scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" }
]
},
{
"type": "checkbox",
"id": "show_cart_icon",
"label": "t:labels.cart_icon",
"default": false
}
]
}
{% endschema %}