<header class="header{% if section.settings.header_sticky %} header--sticky{% endif %}{% if section.settings.header_width_type == 'full_width' %} header--full-width{% else %} container-width{% endif %}">
  <div class="header__inner">
     <button class="header__toggle" type="button" aria-expanded="false" aria-controls="header-drawer" onclick="openHeaderDrawer()">
      {{ 'icon-hamburger.svg' | inline_asset_content }}
      <span class="visually-hidden">{{ 'header.open_menu' | t }}</span>
    </button>
    <div class="header__brand">
      <a class="header__brand-link" href="{{ routes.root_url }}">
        {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | default: 280 | image_tag: alt: shop.name }}
        {% else %}
          <span class="header__brand-text">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>



    <nav class="header__nav" aria-label="{{ 'header.menu' | t }}">
      {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
        <ul class="header__menu-list">
          {% for link in section.settings.menu.links %}
            {% assign has_children = false %}
            {% if link.links and link.links.size > 0 %}{% assign has_children = true %}{% endif %}
            <li class="header__menu-item{% if has_children %} header__menu-item--has-children{% endif %}">
              <a href="{{ link.url }}" class="header__menu-link"{% if has_children %} aria-haspopup="true" aria-expanded="false"{% endif %}>
                <span>{{ link.title }}</span>
                {% if has_children %}
                  <span class="header__caret header__caret--down" aria-hidden="true">
                    <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                {% endif %}
              </a>

              {% if has_children %}
                <ul class="header__submenu">
                  {% for child in link.links %}
                    {% assign has_grandchildren = false %}
                    {% if child.links and child.links.size > 0 %}{% assign has_grandchildren = true %}{% endif %}
                    <li class="header__submenu-item{% if has_grandchildren %} header__submenu-item--has-children{% endif %}">
                      <a href="{{ child.url }}" class="header__submenu-link"{% if has_grandchildren %} aria-haspopup="true" aria-expanded="false"{% endif %}>
                        <span>{{ child.title }}</span>
                        {% if has_grandchildren %}
                          <span class="header__caret header__caret--forward" aria-hidden="true">
                            <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                              <path d="M1 1L5 5L1 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                          </span>
                        {% endif %}
                      </a>

                      {% if has_grandchildren %}
                        <ul class="header__submenu header__submenu--flyout">
                          {% for grandchild in child.links %}
                            <li class="header__submenu-item">
                              <a href="{{ grandchild.url }}" class="header__submenu-link">{{ grandchild.title }}</a>
                            </li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    <div class="header__icons">
      {% if section.settings.show_wishlist_icon %}
        <a class="header__icon" href="/pages/wishlist" aria-label="{{ 'header.wishlist_icon' | t }}">
          {{ 'icon-wishlist.svg' | inline_asset_content }}
        </a>
      {% endif %}

      {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
        <a class="header__icon hide-mobile" href="{{ routes.account_login_url }}" aria-label="{{ 'header.account_icon' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}

      {% if section.settings.show_search_icon %}
        <a class="header__icon" href="{{ routes.search_url }}" aria-label="{{ 'header.search_icon' | t }}">
          {{ 'icon-search.svg' | inline_asset_content }}
        </a>
      {% endif %}

      {% if section.settings.show_cart_icon %}
        <a class="header__icon" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart_icon' | t }}">
          {% if cart.item_count > 0 %}
            <sup>{{ cart.item_count }}</sup>
          {% endif %}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
      {% endif %}
    </div>
  </div>

  <div id="header-drawer" class="header__drawer" aria-hidden="true">
    <div class="header__drawer-panel">
      <div class="header__drawer-top">
        <a class="header__drawer-brand" href="{{ routes.root_url }}">
          {% if section.settings.logo %}
            {{ section.settings.logo | image_url: width: section.settings.logo_width_mobile | default: 180 | image_tag: alt: shop.name }}
          {% else %}
            <span class="header__brand-text">{{ shop.name }}</span>
          {% endif %}
        </a>
        <button class="header__drawer-close" type="button" aria-label="{{ 'header.close_menu' | t }}" onclick="closeHeaderDrawer()">
          {{ 'icon-close.svg' | inline_asset_content }}
        </button>
      </div>

      <nav class="header__drawer-nav" aria-label="{{ 'header.menu' | t }}">
        {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
          <ul class="header__drawer-menu">
            {% for link in section.settings.menu.links %}
              {% assign has_children = false %}
              {% if link.links and link.links.size > 0 %}{% assign has_children = true %}{% endif %}
              <li class="header__drawer-item{% if has_children %} header__drawer-item--has-children{% endif %}">
                <div class="header__drawer-item-top">
                  <a href="{{ link.url }}">{{ link.title }}</a>
                  {% if has_children %}
                    <button class="header__drawer-submenu-toggle" type="button" aria-expanded="false" aria-controls="drawer-submenu-{{ forloop.index0 }}">
                      <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="visually-hidden">{{ 'header.open_submenu' | t }}</span>
                    </button>
                  {% endif %}
                </div>

                {% if has_children %}
                  <div id="drawer-submenu-{{ forloop.index0 }}" class="header__drawer-submenu">
                    <ul class="header__drawer-submenu-inner">
                      {% for child in link.links %}
                        {% assign has_grandchildren = false %}
                        {% if child.links and child.links.size > 0 %}{% assign has_grandchildren = true %}{% endif %}

                        {% if has_grandchildren %}
                          <li class="header__drawer-subitem header__drawer-subitem--has-children">
                            <div class="header__drawer-item-top header__drawer-item-top--level2">
                              <a href="{{ child.url }}">{{ child.title }}</a>
                              <button class="header__drawer-submenu-toggle" type="button" aria-expanded="false" aria-controls="drawer-submenu-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}">
                                <svg width="12" height="8" viewBox="0 0 12 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                <span class="visually-hidden">{{ 'header.open_submenu' | t }}</span>
                              </button>
                            </div>
                            <div id="drawer-submenu-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="header__drawer-submenu header__drawer-submenu--level3">
                              <ul class="header__drawer-submenu-inner">
                                {% for grandchild in child.links %}
                                  <li>
                                    <a href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                                  </li>
                                {% endfor %}
                              </ul>
                            </div>
                          </li>
                        {% else %}
                          <li class="header__drawer-subitem">
                            <a href="{{ child.url }}">{{ child.title }}</a>
                          </li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </nav>

      <div class="header__drawer-icons">

        {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
          <a class="header__drawer-icon" href="{{ routes.account_login_url }}">
            {{ 'icon-account.svg' | inline_asset_content }}
            <span>{{ 'header.account_icon' | t }}</span>
          </a>
        {% endif %}


      </div>
    </div>
  </div>

  {% render 'header-scripts' %}

  <script>
    (function () {
      var headerRoot = document.currentScript.closest('.header');
      if (!headerRoot) return;

      /* ---------------------------------------------------------------
         MOBILE DRAWER: nested accordions, works for unlimited depth.
         One delegated click listener handles every toggle button,
         no height math needed (grid-template-rows animates itself,
         see the stylesheet for `.header__drawer-submenu`).
      --------------------------------------------------------------- */
      var drawer = headerRoot.querySelector('#header-drawer');
      if (drawer) {
        drawer.addEventListener('click', function (e) {
          var btn = e.target.closest('.header__drawer-submenu-toggle');
          if (!btn) return;
          var li = btn.closest('li');
          if (!li) return;
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          li.classList.toggle('header__drawer-item--open', !expanded);
        });
      }

      /* ---------------------------------------------------------------
         DESKTOP: hover/focus flyouts with a short "grace period" before
         closing, so moving the mouse from the link into the dropdown
         (or from a level-2 item into its level-3 flyout) doesn't cause
         it to vanish instantly.
      --------------------------------------------------------------- */
      var CLOSE_DELAY = 300; // ms - tweak if it still feels too fast/slow

      var desktopItems = headerRoot.querySelectorAll(
        '.header__nav .header__menu-item--has-children, .header__nav .header__submenu-item--has-children'
      );

      desktopItems.forEach(function (item) {
        var closeTimer = null;
        var trigger = item.querySelector(':scope > a');
        var flyout = item.querySelector(':scope > .header__submenu');

        function open() {
          clearTimeout(closeTimer);
          item.classList.add('is-open');
          if (trigger) trigger.setAttribute('aria-expanded', 'true');
          positionFlyout();
        }

        function closeSoon() {
          clearTimeout(closeTimer);
          closeTimer = setTimeout(function () {
            item.classList.remove('is-open');
            if (trigger) trigger.setAttribute('aria-expanded', 'false');
          }, CLOSE_DELAY);
        }

        // If a third-level flyout would overflow the right edge of the
        // viewport, flip it to open toward the left instead.
        function positionFlyout() {
          if (!flyout || !flyout.classList.contains('header__submenu--flyout')) return;
          flyout.classList.remove('header__submenu--flyout-left');
          var rect = flyout.getBoundingClientRect();
          if (rect.right > window.innerWidth) {
            flyout.classList.add('header__submenu--flyout-left');
          }
        }

        item.addEventListener('mouseenter', open);
        item.addEventListener('mouseleave', closeSoon);
        item.addEventListener('focusin', open);
        item.addEventListener('focusout', function (e) {
          if (!item.contains(e.relatedTarget)) closeSoon();
        });
      });
    })();
  </script>
</header>

{% stylesheet %}
  #shopify-section-{{ section.id }} {
    /* Drawer / accordion transition (a bit slower, matches the slide-in panel) */
    --transition-default: 0.45s cubic-bezier(0.65, 0, 0.35, 1);
    /* Desktop dropdown / flyout transition (snappier, for hover UI) */
    --transition-menu: 0.2s ease;
  }

  .header {
    width: 100%;
    background: var(--color-background);
    color: var(--color-foreground);
        padding-top: 20px;
    padding-bottom: 20px;
  }

  .header--sticky {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    margin: 0 auto;
  }

  .header--container-width .header__inner {
    max-width: var(--header-max-width);
  }

  .header--full-width .header__inner {
    max-width: 100%;
  }

  .header__brand-link,
  .header__drawer-brand {
    display: inline-flex;
    align-items: center;
  }

  .header__brand-text {
    font-weight: 700;
    font-size: 1.2rem;
  }

  .header__toggle {
    display: none;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__nav {
    flex: 1;
  }

  .header__menu-list {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    list-style: none;
    justify-content: center;
    margin: 0;
    padding: 0;
  }

  .header__menu-item {
    position: relative;
  }

  .header__menu-link,
  .header__submenu-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: inherit;
    text-decoration: none;
  }

  /* Caret / chevron icons */
  .header__caret {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .header__caret--down svg {
    transition: transform var(--transition-menu);
  }

  .header__menu-item.is-open > .header__menu-link .header__caret--down svg {
    transform: rotate(180deg);
  }

  .header__caret--forward svg {
    transition: transform var(--transition-menu);
  }

  .header__submenu-item.is-open > .header__submenu-link .header__caret--forward svg {
    transform: translateX(2px);
  }

  /* ---------------------------------------------------------------
     Desktop dropdown / flyout submenus
     Opacity + transform + delayed visibility gives a smooth fade
     instead of the old instant show/hide.
  --------------------------------------------------------------- */
  .header__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-background);
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.08);
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0.5rem 0;
    min-width: 220px;
    z-index: 60;

    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity var(--transition-menu), transform var(--transition-menu), visibility 0s linear var(--transition-menu);
  }

  .header__menu-item.is-open > .header__submenu,
  .header__menu-item:focus-within > .header__submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity var(--transition-menu), transform var(--transition-menu), visibility 0s linear 0s;
  }

  .header__submenu-item {
    position: relative;
  }

  /* Third level: flyout that opens to the right of its parent item */
  .header__submenu--flyout {
    top: -0.5rem;
    left: 100%;
    margin: 0 0 0 0.5rem;
    transform: translateX(6px);
  }

  .header__submenu--flyout.header__submenu--flyout-left {
    left: auto;
    right: 100%;
    margin: 0 0.5rem 0 0;
  }

  .header__submenu-item.is-open > .header__submenu--flyout,
  .header__submenu-item:focus-within > .header__submenu--flyout {
    transform: translateX(0);
  }

  .header__submenu--flyout.header__submenu--flyout-left.header__submenu {
    transform: translateX(-6px);
  }

  .header__submenu-item.is-open > .header__submenu--flyout.header__submenu--flyout-left,
  .header__submenu-item:focus-within > .header__submenu--flyout.header__submenu--flyout-left {
    transform: translateX(0);
  }

  .header__submenu-item a {
    color: inherit;
    text-decoration: none;
  }

  .header__submenu-item .header__submenu-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
  }

  .header__submenu-item--has-children > .header__submenu-link {
    padding-right: 0.75rem;
  }

  .header__icons {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: inherit;
    text-decoration: none;
    position: relative;
  }

  .header__icon sup {
    position: absolute;
    top: -0.35rem;
    right: -0.35rem;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 999px;
    padding: 0 0.35rem;
    font-size: 0.65rem;
    line-height: 1;
  }

  /* Drawer overlay */
  .header__drawer {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-default);
    z-index: 100;
  }

  .header__drawer--open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Drawer panel: full height, slides in from the left */
  .header__drawer-panel {
    width: 100%;
    max-width: 467px;
    height: 100%;
    background: var(--color-background);
    color: var(--color-foreground);
    box-shadow: 2px 0 24px rgba(0, 0, 0, 0.16);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform var(--transition-default);
  }

  .header__drawer--open .header__drawer-panel {
    transform: translateX(0);
  }

  .header__drawer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .header__drawer-close {
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__drawer-menu {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__drawer-item,
  .header__drawer-subitem {
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .header__drawer-subitem {
    border-bottom-color: rgba(0, 0, 0, 0.04);
  }

  .header__drawer-subitem > a {
    display: block;
    padding: 0.75rem 1rem 0.75rem 2rem;
    color: inherit;
    text-decoration: none;
  }

  .header__drawer-item-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
        position: relative;
  }

  .header__drawer-item-top > a {
    flex: 1;
    display: block;
    padding: 0.9rem 1rem;
    color: inherit;
    text-decoration: none;
  }

  .header__drawer-item-top--level2 > a {
    padding: 0.75rem 1rem 0.75rem 2rem;
    font-size: 0.92rem;
    opacity: 0.9;
  }

  .header__drawer-submenu-toggle {
 border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    padding: 0.9rem 1rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
  }
.header__drawer-submenu-toggle:hover{
  background: unset;
  color: unset;
}
  .header__drawer-submenu-toggle svg {
    transition: transform var(--transition-default);
  }

  .header__drawer-item--open > .header__drawer-item-top .header__drawer-submenu-toggle svg,
  .header__drawer-item--open > .header__drawer-item-top--level2 .header__drawer-submenu-toggle svg {
    transform: rotate(180deg);
  }

  /* ---------------------------------------------------------------
     Nested accordion submenus (mobile drawer).
     grid-template-rows: 0fr -> 1fr animates height without any JS
     measuring, and it keeps working correctly no matter how many
     levels are nested inside one another.
  --------------------------------------------------------------- */
  .header__drawer-submenu {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--transition-default);
  }

  .header__drawer-item--open > .header__drawer-submenu {
    grid-template-rows: 1fr;
  }

  .header__drawer-submenu-inner {
    list-style: none;
    margin: 0;
    padding: 0;
    overflow: hidden;
    min-height: 0;
  }

  .header__drawer-submenu-inner > li > a {
    display: block;
    padding: 0.75rem 1rem 0.75rem 2rem;
    color: inherit;
    text-decoration: none;
  }

  /* extra indent for third-level leaf links */
  .header__drawer-submenu .header__drawer-submenu-inner > li > a {
    padding-left: 3rem;
    font-size: 0.9rem;
    opacity: 0.85;
  }

  .header__drawer-icons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    margin-top: auto;
  }

  .header__drawer-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: inherit;
    text-decoration: none;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: rgba(0, 0, 0, 0.03);
  }

  .header__drawer-icon span {
    font-size: 0.95rem;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 860px) {
    .header__inner {
      max-width: var(--header-max-width-mobile);
    }

    .header__nav
     {
      display: none;
    }

    .header__toggle {
      display: inline-flex;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "select",
      "id": "section_color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme_1",
      "options": [
        { "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
        { "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" }
      ]
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "select",
      "id": "header_width_type",
      "label": "t:labels.header_width_type",
      "default": "container_width",
      "options": [
        { "value": "container_width", "label": "t:options.header_width_type.container_width" },
        { "value": "full_width", "label": "t:options.header_width_type.full_width" }
      ]
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "label": "t:labels.logo_width_desktop",
      "min": 80,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 280
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "t:labels.logo_width_mobile",
      "min": 60,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 180
    },
    {
      "type": "checkbox",
      "id": "header_sticky",
      "label": "t:labels.header_sticky",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_wishlist_icon",
      "label": "t:labels.wishlist_icon",
