"settings": [
{
"type": "select",
"id": "section_color_scheme",
"label": "t:labels.color_scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
{ "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
{ "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
]
},
{
"type": "image_picker",
"id": "logo",
"label": "t:labels.logo"
},
{
"type": "select",
"id": "header_width_type",
"label": "t:labels.header_width_type",
"default": "container_width",
"options": [
{ "value": "container_width", "label": "t:options.header_width_type.container_width" },
{ "value": "full_width", "label": "t:options.header_width_type.full_width" }
]
},
{
"type": "range",
"id": "logo_width_desktop",
"label": "t:labels.logo_width_desktop",
"min": 80,
"max": 400,
"step": 10,
"unit": "px",
"default": 280
},
{
"type": "range",
"id": "logo_width_mobile",
"label": "t:labels.logo_width_mobile",
"min": 60,
"max": 300,
"step": 10,
"unit": "px",
"default": 180
},
{
"type": "checkbox",
"id": "header_sticky",
"label": "t:labels.header_sticky",
"default": true
},
{
"type": "checkbox",
"id": "enable_drawer_desktop",
"label": "t:labels.enable_drawer_desktop",
"info": "t:labels.enable_drawer_desktop_info",
"default": false
},
{
"type": "checkbox",
"id": "enable_transparent_header",
"label": "t:labels.enable_transparent_header",
"info": "t:labels.enable_transparent_header_info",
"default": false
},
{
"type": "color",
