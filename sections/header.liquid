{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'mega-menu.css' | asset_url | stylesheet_tag }}
{{ 'megemenu-script.js' | asset_url | script_tag }}
<div
  class="section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }} v-header{% if section.settings.enable_drawer_desktop %} header--drawer-desktop{% endif %}{% if section.settings.enable_transparent_header %} allow-transparent-header{% endif %}"
  
id="header-wrapper-{{ section.id }}" {% if section.settings.header_sticky %}data-header-sticky="true" {% endif %}>
  <header
    class="header{% if section.settings.header_width_type == 'full_width' %} full-width{% else %} container-width{% endif %}">
    {% assign header_logo_styles = '--header-logo-width-desktop: ' | append: section.settings.logo_width_desktop |
    append: 'px; --header-logo-width-mobile: ' | append: section.settings.logo_width_mobile | append: 'px;' %}
    <div class="header__inner">
      <button class="header__toggle" type="button" aria-expanded="false" aria-controls="header-drawer"
        onclick="openHeaderDrawer(event)">
        {{ 'icon-hamburger-simple.svg' | inline_asset_content }}
        <span class="visually-hidden">{{ 'header.open_menu' | t }}</span>
      </button>
      <div class="header__brand">
        <a class="header__brand-link" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
          {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: section.settings.logo_width_desktop | default: 280 | image_tag:
          class: 'header__logo', alt: shop.name }}
          {% else %}
          <span class="header__brand-text">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>



      <nav class="header__nav" aria-label="{{ 'header.menu' | t }}">
        {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
        <ul class="header__menu-list">
          {% for link in section.settings.menu.links %}
          {%- comment -%}
          Match this top-level link to a mega menu block by comparing
          the link's title against the block's "menu_item_handle"
          text setting (exact match, case-sensitive).
          {%- endcomment -%}
          {% assign mega_menu_block = blank %}
          {% for block in section.blocks %}
          {% if block.type == 'mega_menu_collection' or block.type == 'mega_menu_banner' %}
          {% if block.settings.menu_item_handle != blank and block.settings.menu_item_handle == link.title %}
          {% assign mega_menu_block = block %}
          {% endif %}
          {% endif %}
          {% endfor %}
          {% render 'header-menu-item', link: link, mode: 'desktop', parent_id: 'desktop-', depth: 0, index:
          forloop.index0, mega_menu_block: mega_menu_block %}
          {% endfor %}
        </ul>
        {% endif %}
      </nav>

      <div class="header__icons">
        {% if section.settings.show_wishlist_icon %}
        <a class="header__icon" href="/pages/wishlist" aria-label="{{ 'header.wishlist_icon' | t }}">
          {{ 'icon-wishlist.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
        <a class="header__icon hide-mobile" href="{{ routes.account_login_url }}"
          aria-label="{{ 'header.account_icon' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
        {% endif %}

        {% if section.settings.show_search_icon %}
        <button class="header__icon" type="button" aria-label="{{ 'header.search_icon' | t }}"
          onclick="openSearchPopup()">
          {{ 'icon-search.svg' | inline_asset_content }}
        </button>
        {% endif %}

        {% if section.settings.show_cart_icon %}
        <a class="header__icon" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart_icon' | t }}">
          {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
          {% endif %}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
        {% endif %}
      </div>
    </div>



    <div id="header-drawer" class="header__drawer" aria-hidden="true">
      <div class="header__drawer-panel">
        <div class="header__drawer-top">
          <a class="header__drawer-brand" href="{{ routes.root_url }}" style="{{ header_logo_styles }}">
            {% if section.settings.logo %}
            {{ section.settings.logo | image_url: width: section.settings.logo_width_mobile | default: 180 | image_tag:
            class: 'header__logo', alt: shop.name }}
            {% else %}
            <span class="header__brand-text">{{ shop.name }}</span>
            {% endif %}
          </a>
          <button class="header__drawer-close" type="button" aria-label="{{ 'header.close_menu' | t }}"
            onclick="closeHeaderDrawer()">
            {{ 'icon-close.svg' | inline_asset_content }}
          </button>
        </div>

        <nav class="header__drawer-nav" aria-label="{{ 't:labels.menu' | t }}">
          {% if section.settings.menu.links and section.settings.menu.links.size > 0 %}
          <ul class="header__drawer-menu">
            {% for link in section.settings.menu.links %}
            {% render 'header-menu-item', link: link, mode: 'drawer', parent_id: 'drawer-', depth: 0, index:
            forloop.index0 %}
            {% endfor %}
          </ul>
          {% endif %}
        </nav>

        <div class="header__drawer-icons">
          <div class="drawer-socials">
            <a class="social-button" href="{{ settings.footer_facebook_url }}" target="_blank" rel="noopener"
              aria-label="Facebook">
              {% if settings.footer_facebook_url != blank %}
              {{ 'icon-fb.svg' | inline_asset_content }}
              {% endif %}
            </a>
            {% if settings.footer_instagram_url != blank %}
            <a class="social-button" href="{{ settings.footer_instagram_url }}" target="_blank" rel="noopener"
              aria-label="Instagram">
              {{ 'icon-insta.svg' | inline_asset_content }}
            </a>
            {% endif %}
            {% if settings.footer_youtube_url != blank %}
            <a class="social-button" href="{{ settings.footer_youtube_url }}" target="_blank" rel="noopener"
              aria-label="YouTube">
              {{ 'icon-youtube.svg' | inline_asset_content }}
            </a>
            {% endif %}
            {% if settings.footer_twitter_url != blank %}
            <a class="social-button" href="{{ settings.footer_twitter_url }}" target="_blank" rel="noopener"
              aria-label="Twitter">
              {{ 'icon-twitter.svg' | inline_asset_content }}
            </a>
            {% endif %}
          </div>
          {% if section.settings.show_account_icon and shop.customer_accounts_enabled %}
          <a class="header__drawer-icon" href="{{ routes.account_login_url }}">
            {{ 'icon-account.svg' | inline_asset_content }}
            <span>{{ 'header.account_icon' | t }}</span>
          </a>
          {% endif %}
          {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
          {% form 'localization', id: 'DrawerLocalizationForm', class: 'drawer__localization' %}

          {%- if localization.available_countries.size > 1 -%}
          <div class="drawer__loc-item">
            <select id="DrawerCountrySelector" name="country_code" aria-label="Country / Currency"
              onchange="this.form.submit()">
              {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}" {% if country.iso_code==localization.country.iso_code %}selected{%
                endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
              {%- endfor -%}
            </select>


          </div>
          {%- endif -%}

          {%- if localization.available_languages.size > 1 -%}
          <div class="drawer__loc-item">
            <select id="DrawerLanguageSelector" name="locale_code" aria-label="Language" onchange="this.form.submit()">
              {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}" {% if language.iso_code==localization.language.iso_code
                %}selected{% endif %}>
                {{ language.endonym_name }}
              </option>
              {%- endfor -%}
            </select>


          </div>
          {%- endif -%}

          {% endform %}
          {%- endif -%}

        </div>
      </div>
    </div>

    {% render 'header-scripts' %}
    {% render 'search-popup', color_scheme: section.settings.search_popup_color_scheme %}
    {% if section.settings.header_sticky %}
    <script>
      (function () {
        var headerWrapper = document.getElementById('header-wrapper-{{ section.id }}');
        if (!headerWrapper) return;

        var scrollThreshold = 50; 
        var isSticky = false;
        var ticking = false;

        function updateStickyState() {
          var scrolled = window.scrollY || window.pageYOffset;

          if (scrolled > scrollThreshold && !isSticky) {
            headerWrapper.classList.add('header--sticky');
            isSticky = true;
          } else if (scrolled <= scrollThreshold && isSticky) {
            headerWrapper.classList.remove('header--sticky');
            isSticky = false;
          }
        }

        window.addEventListener('scroll', function () {
          if (!ticking) {
            window.requestAnimationFrame(function () {
              updateStickyState();
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });

       
        updateStickyState();
      })();
    </script>
    {% endif %}
  </header>
  {%- comment -%}
  Mega menu panels — rendered ONCE here, as siblings of .header__inner,
  not nested inside any <li>. This is what makes them span the full
    <header> width instead of being boxed in by a single nav item's
      width. Each panel is hidden by default (CSS) and toggled via
      data-mega-menu-trigger matching on the nav link.
      {%- endcomment -%}
      {% for block in section.blocks %}
      {% if block.type == 'mega_menu_collection' or block.type == 'mega_menu_banner' %}
      {% assign mm_link = blank %}
      {% for link in section.settings.menu.links %}
      {% if block.settings.menu_item_handle != blank and link.title == block.settings.menu_item_handle %}
      {% assign mm_link = link %}
      {% endif %}
      {% endfor %}
      {% if mm_link != blank %}
      {% render 'mega-menu', block: block, link: mm_link %}
      {% endif %}
      {% endif %}
      {% endfor %}
</div>

<style>
  #shopify-section-{{ section.id }} {
    --transition-default: 0.45s cubic-bezier(0.65, 0, 0.35, 1);
  }

  {% if section.settings.enable_transparent_header %}
  #header-wrapper-{{ section.id }}.allow-transparent-header .header {
    background: transparent;
    color: {{ section.settings.transparent_header_text_color }};
  }
  {% endif %}
</style>

