{%- style -%}
.text-logo-section {
position: relative;
width: 100%;
overflow: hidden;
padding: {{ section.settings.padding_top_mobile | default: 20 }}px 0 {{ section.settings.padding_bottom_mobile |
default: 35 }}px;
}

.text-logo-section__title {
margin: 0;
text-align: center;
font-family: {{ section.settings.font_family.family }}, sans-serif;
font-weight: {{ section.settings.font_family.weight | default: 700 }};
font-size: clamp(30px, 11vw, {{ section.settings.font_size_desktop | default: 120 }}px);
line-height: 0.82;
letter-spacing: -0.05em;
user-select: none;
{%- if section.settings.text_color_type == 'solid' -%}
color: {{ section.settings.text_color | default: '#f8f8f8' }};
{%- else -%}
background: linear-gradient(
to bottom,
{{ section.settings.gradient_color_start | default: '#f8f8f8' }} 0%,
{{ section.settings.gradient_color_middle | default: '#c8c8c8' }} 45%,
{{ section.settings.gradient_color_end | default: '#202020' }} 100%
);
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
color: transparent;
{%- endif -%}
}

.text-logo-section::after {
content: '';
position: absolute;
left: 0;
bottom: 0;
width: 100%;
height: 70px;
pointer-events: none;
background: linear-gradient(
to bottom,
color-mix(in srgb, var(--color-background) 0%, transparent) 0%,
color-mix(in srgb, var(--color-background) 15%, transparent) 30%,
color-mix(in srgb, var(--color-background) 45%, transparent) 60%,
color-mix(in srgb, var(--color-background) 80%, transparent) 85%,
var(--color-background) 100%
);
}

@media (min-width: 768px) {
.text-logo-section {
padding: {{ section.settings.padding_top_desktop | default: 10 }}px 0 {{ section.settings.padding_bottom_desktop |
default: 35 }}px;
}

.text-logo-section__title {
font-size: clamp(120px, 29vw, {{ section.settings.font_size_desktop | default: 120 }}px);
}

.text-logo-section::after {
height: 140px;
}
}
{{ section.settings.font_family | font_face }}
{%- endstyle -%}



<section class="text-logo-section section-color-scheme--{{ section.settings.section_color_scheme | default: 'scheme_1' }}">
  <h1 class="text-logo-section__title">{{ section.settings.text | default: 'Crystal Clean' }}</h1>
</section>
{% schema %}
{
"name": "Text Logo",
"tag": "section",
"class": "text-logo-wrapper",
"settings": [
{
"type": "select",
"id": "section_color_scheme",
"label": "t:labels.color_scheme",
"default": "scheme_1",
"options": [
{ "value": "scheme_1", "label": "t:options.color_scheme.scheme_1" },
{ "value": "scheme_2", "label": "t:options.color_scheme.scheme_2" },
{ "value": "scheme_3", "label": "t:options.color_scheme.scheme_3" },
{ "value": "scheme_4", "label": "t:options.color_scheme.scheme_4" }
]
},
{
"type": "text",
"id": "text",
"label": "Text",
"default": "Crystal Clean"
},
{
"type": "font_picker",
"id": "font_family",
"label": "Font family",
"default": "assistant_n4"
},
{
"type": "range",
"id": "font_size_desktop",
"label": "Max font size (desktop)",
"min": 60,
"max": 200,
"step": 5,
"unit": "px",
"default": 120
},
{
"type": "select",
"id": "text_color_type",
"label": "Text color style",
"default": "gradient",
"options": [
{ "value": "gradient", "label": "Gradient (default)" },
{ "value": "solid", "label": "Solid color" }
]
},
{
"type": "color",
"id": "text_color",
"label": "Text color",
"default": "#f8f8f8",
"visible_if": "{{ section.settings.text_color_type == 'solid' }}"
},
{
"type": "color",
"id": "gradient_color_start",
"label": "Gradient color (top)",
"default": "#f8f8f8",
"visible_if": "{{ section.settings.text_color_type == 'gradient' }}"
},
{
"type": "color",
"id": "gradient_color_middle",
"label": "Gradient color (middle)",
"default": "#c8c8c8",
"visible_if": "{{ section.settings.text_color_type == 'gradient' }}"
},
{
"type": "color",
"id": "gradient_color_end",
"label": "Gradient color (bottom)",
"default": "#202020",
"visible_if": "{{ section.settings.text_color_type == 'gradient' }}"
},
{
"type": "header",
"content": "t:headers.desktop_padding"
},
{
"type": "range",
"id": "padding_top_desktop",
"label": "t:labels.padding_top",
"min": 0,
"max": 100,
"step": 2,
"unit": "px",
"default": 10
},
{
"type": "range",
"id": "padding_bottom_desktop",
"label": "t:labels.padding_bottom",
"min": 0,
"max": 100,
"step": 5,
"unit": "px",
"default": 35
},
{
"type": "header",
"content": "t:headers.mobile_padding"
},
{
"type": "range",
"id": "padding_top_mobile",
"label": "t:labels.padding_top",
"min": 0,
"max": 60,
"step": 2,
"unit": "px",
"default": 20
},
{
"type": "range",
"id": "padding_bottom_mobile",
"label": "t:labels.padding_bottom",
"min": 0,
"max": 60,
"step": 5,
"unit": "px",
"default": 35
}
],
"presets": [
{
"name": "Text Logo"
}
]
}
{% endschema %}